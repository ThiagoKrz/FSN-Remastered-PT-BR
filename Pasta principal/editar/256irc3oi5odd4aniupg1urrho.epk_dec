DAT
id=qid::label=str::text=lstr::
67210::$$$message_0624_0000_0000$$$::"Eu ainda vou te levar pra casa. Eu não vou voltar sozinho."[lr]::
67211::$$$message_0624_0000_0001$$$::Eu não preciso nem pensar a respeito.[lr]::
67212::$$$message_0624_0000_0002$$$::Não há alternativa na minha mente.::
67213::$$$message_0624_0001_0000$$$::"[w l=4][line4]"[lr]::
67214::$$$message_0624_0001_0001$$$::Illya só me encara de volta surpresa.[lr]::
67215::$$$message_0624_0001_0002$$$::Eu pego sua mão.[lr]::
67216::$$$message_0624_0001_0003$$$::"Vamos lá, Illya. Nós vamos voltar pra casa antes que eles nos encontrem."[lr]::
67217::$$$message_0624_0001_0004$$$::Eu puxo seu pequeno, leve corpo e começo a caminhar.::
67218::$$$message_0624_0002_0000$$$::"Estou chocada. Qualquer coisa que eu fale para você é inútil."[lr]::
67219::$$$message_0624_0002_0001$$$::Illya começa a caminhar sem resistir.[lr]::
67220::$$$message_0624_0002_0002$$$::"Sério. Não tem chance disso terminar bem."[lr]::
67221::$$$message_0624_0002_0003$$$::Ela alegremente fecha a sua mão em cima da minha.::

