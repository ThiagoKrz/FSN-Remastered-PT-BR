DAT
id=qid::label=str::text=lstr::
67222::$$$message_0625_0000_0000$$$::"Eu ainda vou te levar pra casa. Eu não vou voltar sozinho."[lr]::
67223::$$$message_0625_0000_0001$$$::Eu não preciso nem pensar a respeito.[lr]::
67224::$$$message_0625_0000_0002$$$::Não há alternativa na minha mente.::
67225::$$$message_0625_0001_0000$$$::"[w l=4][line4]"[lr]::
67226::$$$message_0625_0001_0001$$$::Illya só me encara de volta surpresa.[lr]::
67227::$$$message_0625_0001_0002$$$::Eu pego sua mão.[lr]::
67228::$$$message_0625_0001_0003$$$::"Vamos lá, Illya. Nós vamos voltar pra casa antes que eles nos encontrem."[lr]::
67229::$$$message_0625_0001_0004$$$::Eu puxo seu pequeno, leve corpo e começo a caminhar.::
67230::$$$message_0625_0002_0000$$$::"Estou chocada. Qualquer coisa que eu fale para você é inútil."[lr]::
67231::$$$message_0625_0002_0001$$$::Illya começa a caminhar sem resistir.[lr]::
67232::$$$message_0625_0002_0002$$$::"Sério. Não tem chance disso terminar bem."[lr]::
67233::$$$message_0625_0002_0003$$$::Ela alegremente fecha a sua mão em cima da minha.::

