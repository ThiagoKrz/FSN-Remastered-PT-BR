DAT
id=qid::label=str::text=lstr::
72119::$$$message_0663_0000_0000$$$::Sua visĂŁo se expande.[lr]::
72120::$$$message_0663_0000_0001$$$::No instante em que Tohsaka Rin escapa da escuridĂŁo, ela esquece que estĂĄ no subterrĂąneo.::
72121::$$$message_0663_0001_0000$$$::O teto numa altura impossĂ­vel e um sol negro.[lr]::
72122::$$$message_0663_0001_0001$$$::A grande caverna nĂŁo Ă© uma caverna, mas sim uma terra desolada.[lr]::
72123::$$$message_0663_0001_0002$$$::Deve haver dois, nĂŁo, trĂȘs quilĂŽmetros de diĂąmetro.[lr]::
72124::$$$message_0663_0001_0003$$$::A distĂąncia estĂĄ uma parede monolĂ­tica.[lr]::
72125::$$$message_0663_0001_0004$$$::...Esse Ă© o comeĂ§o e o fim dessa guerra.[lr]::
72126::$$$message_0663_0001_0005$$$::Deve haver uma grande cratera acima do penhasco.[lr]::
72127::$$$message_0663_0001_0006$$$::LĂĄ estĂĄ o sistema que esteve ativado por duzentos anos.::
72128::$$$message_0663_0002_0000$$$::A rocha gigantesca que contĂ©m um grande cĂ­rculo mĂĄgico, o Santo Graal Maior, emite chamas negras do seu centro circular.::
72129::$$$message_0663_0003_0000$$$::O movimento embrionĂĄrio da sombra negra.[lr]::
72130::$$$message_0663_0003_0001$$$::A luz que ilumina o deserto Ă© uma onda de energia mĂĄgica.[lr]::
72131::$$$message_0663_0003_0002$$$::...De acordo com os registros dos Tohsakas, isso Ă© o que vocĂȘ chamaria de o altar do inĂ­cio.[lr]::
72132::$$$message_0663_0003_0003$$$::O meio que leva ao meio.[lr]::
72133::$$$message_0663_0003_0004$$$::O circuito circular, o mundo do coraĂ§ĂŁo, Heaven's Feel.[lr]::
72134::$$$message_0663_0003_0005$$$::Ele contĂ©m uma quantidade imensurĂĄvel de energia mĂĄgica, criando um mundo alienĂ­gena que faz jus ao seu nome.::
72135::$$$message_0663_0004_0000$$$::"Esse Ă© o Angra Mainyu... EntĂŁo ele nĂŁo ganhou o nome 'todos os males deste mundo' Ă  toa, huh?"[lr]::
72136::$$$message_0663_0004_0001$$$::Rin fala sem preocupaĂ§ĂŁo enquanto caminha em direĂ§ĂŁo ao altar.[lr]::
72137::$$$message_0663_0004_0002$$$::...Ela estĂĄ preocupada com Shirou e a Rider, mas a sua situaĂ§ĂŁo nĂŁo Ă© das melhores tambĂ©m.[lr]::
72138::$$$message_0663_0004_0003$$$::A energia mĂĄgica no Santo Graal Maior nĂŁo Ă© algo que um humano conseguiria controlar.::
72139::$$$message_0663_0005_0000$$$::O turbilhĂŁo de energia mĂĄgica pode ser chamado de infinito.[lr]::
72140::$$$message_0663_0005_0001$$$::Tem tanta energia mĂĄgica que ela nunca irĂĄ acabar, mesmo se todos os magos do mundo vierem aqui e usar quaisquer taumaturgias que eles quiserem.[lr]::
72141::$$$message_0663_0005_0002$$$::Ă mais do que qualquer pessoa possa usar durante o tempo de uma vida, e portanto pode ser chamado de infinito.::
72142::$$$message_0663_0006_0000$$$::"...Nada Ă© impossĂ­vel, huh? O Santo Graal pode mesmo realizar qualquer desejo."[lr]::
72143::$$$message_0663_0006_0001$$$::Sua determinaĂ§ĂŁo quase se quebra, confrontada com a premoniĂ§ĂŁo de morte.[lr]::
72144::$$$message_0663_0006_0002$$$::Mantendo o seu espĂ­rito elevado com conversa fiada, ela continua caminhando.::
72145::$$$message_0663_0007_0000$$$::[w l=3][line3]Ela estĂĄ sendo cuidadosa por causa do Assassin e do Matou Zouken.[lr]::
72146::$$$message_0663_0007_0001$$$::Matou Sakura nĂŁo Ă© uma ameaĂ§a.[lr]::
72147::$$$message_0663_0007_0002$$$::Ela perdeu a sanidade, e Rin nĂŁo sente nenhum perigo vindo dela.[lr]::
72148::$$$message_0663_0007_0003$$$::Afinal de contas, ela Ă© apenas a marionete do Zouken.[lr]::
72149::$$$message_0663_0007_0004$$$::O maior inimigo da Rin Ă© o Matou Zouken.[lr]::
72150::$$$message_0663_0007_0005$$$::A luta contra a Matou Sakura nĂŁo Ă© importante.::
72151::$$$message_0663_0008_0000$$$::"......Estranho. Eu consigo chegar atĂ© o altar."[lr]::
72152::$$$message_0663_0008_0001$$$::Zouken nĂŁo permitiria que um intruso chegasse tĂŁo longe.[lr]::
72153::$$$message_0663_0008_0002$$$::Se ele estĂĄ planejando atacĂĄ-la, serĂĄ no caminho para o altar.[lr]::
72154::$$$message_0663_0008_0003$$$::Mas isso nĂŁo estĂĄ acontecendo, e a Rin estĂĄ prestes a chegar ao seu destino.::
72155::$$$message_0663_0009_0000$$$::"[w l=8][line8]"[lr]::
72156::$$$message_0663_0009_0001$$$::Ela pensa.[lr]::
72157::$$$message_0663_0009_0002$$$::Por que o Zouken nĂŁo estĂĄ interferindo?  Por que ela nĂŁo consegue sentir a sua presenĂ§a e nem a do Assassin?[lr]::
72158::$$$message_0663_0009_0003$$$::Ela faz uma suposiĂ§ĂŁo.[lr]::
72159::$$$message_0663_0009_0004$$$::Ela nega a possibilidade, mas aceita facilmente.[lr]::
72160::$$$message_0663_0009_0005$$$::NĂŁo, ela Ă© forĂ§ada a aceitar.[lr]::
72161::$$$message_0663_0009_0006$$$::Porque...::
72162::$$$message_0663_0010_0000$$$::"[w l=3][line3]Estou feliz, Nee-san. VocĂȘ escolheu vir aqui ao invĂ©s de fugir."::
72163::$$$message_0663_0011_0000$$$::...Sua suposiĂ§ĂŁo acaba se tornando uma verdade.::
72164::$$$message_0663_0012_0000$$$::Ela olha para cima.[lr]::
72165::$$$message_0663_0012_0001$$$::No topo do penhasco.[lr]::
72166::$$$message_0663_0012_0002$$$::Com o sol negro atrĂĄs dela, Matou Sakura dĂĄ as boas-vindas Ă  sua irmĂŁ mais velha.::
72167::$$$message_0663_0013_0000$$$::"[w l=8][line8]!"[lr]::
72168::$$$message_0663_0013_0001$$$::Rin recua um pouco, esmagada pela pressĂŁo.[lr]::
72169::$$$message_0663_0013_0002$$$::...A garota foi transfigurada alĂ©m do que a Rin esperava.[lr]::
72170::$$$message_0663_0013_0003$$$::Angra Mainyu Ă© um Servo sem forma.[lr]::
72171::$$$message_0663_0013_0004$$$::Ă apenas uma sombra que toma uma forma usando o desejo das pessoas.[lr]::
72172::$$$message_0663_0013_0005$$$::Portanto, seu poder depende do seu Mestre.::
72173::$$$message_0663_0014_0000$$$::Matou Sakura agora Ă© Angra Mainyu.[lr]::
72174::$$$message_0663_0014_0001$$$::"Todos os males deste mundo", a funĂ§ĂŁo de emitir a maldiĂ§ĂŁo Ă© a garota chamada Matou Sakura.::
72175::$$$message_0663_0015_0000$$$::"...Merda. Se o Kirei estivesse aqui, ele te chamaria de mensageira de Deus."[lr]::
72176::$$$message_0663_0015_0001$$$::Rin olha para a Sakura, que se transformou em um poĂ§o sem fundo de energia mĂĄgica, e libera a sua espada de jĂłias.[lr]::
72177::$$$message_0663_0015_0002$$$::[w l=3][line3]Mas ela serĂĄ capaz de se igualar ao ser acima dela?::
72178::$$$message_0663_0016_0000$$$::Existem duas funĂ§Ă”es para armas que apoiam equipamentos taumatĂșrgicos e cerimoniais que auxiliam em rituais.[lr]::
72179::$$$message_0663_0016_0001$$$::Uma funĂ§ĂŁo Ă© amplificar.[lr]::
72180::$$$message_0663_0016_0002$$$::Ă como uma reserva, aumentando e complementando a energia mĂĄgica do mago e fortalecendo o encantamento em si.[lr]::
72181::$$$message_0663_0016_0003$$$::Esses itens sĂŁo considerados equipamentos auxiliares ortodoxos, e magos carregam pelo menos um deles. As jĂłias da Rin estĂŁo classificadas nesse grupo.::
72182::$$$message_0663_0017_0000$$$::A outra Ă© uma funĂ§ĂŁo limitada.[lr]::
72183::$$$message_0663_0017_0001$$$::Ă um item mĂĄgico especial onde a arma em si se torna a taumaturgia.[lr]::
72184::$$$message_0663_0017_0002$$$::Ele Ă© ativado usando a energia mĂĄgica do mago e realiza um mistĂ©rio divino predeterminado.[lr]::
72185::$$$message_0663_0017_0003$$$::Sua maior vantagem Ă© que ela permite ao mago usar taumaturgia que ele nĂŁo Ă© capaz de usar normalmente.::
72186::$$$message_0663_0018_0000$$$::Ele possui apenas uma aplicaĂ§ĂŁo e portanto carece de versatilidade, mas por essa razĂŁo o seu poder Ă© imenso.[lr]::
72187::$$$message_0663_0018_0001$$$::Uma lanĂ§a que sempre perfura o coraĂ§ĂŁo,[lr]::
72188::$$$message_0663_0018_0002$$$::uma rĂ©dea que escraviza bestas sagradas,[lr]::
72189::$$$message_0663_0018_0003$$$::uma adaga que cancela qualquer efeito mĂĄgico.[lr]::
72190::$$$message_0663_0018_0004$$$::Os Fantasmas Nobres dos Servos normalmente estĂŁo classificados nesse grupo.::
72191::$$$message_0663_0019_0000$$$::"[w l=8][line8]"[lr]::
72192::$$$message_0663_0019_0001$$$::EntĂŁo, qual delas Ă© a funĂ§ĂŁo da espada de jĂłias?[lr]::
72193::$$$message_0663_0019_0002$$$::Ă um equipamento auxiliar que dĂĄ energia mĂĄgica ao usuĂĄrio,[lr]::
72194::$$$message_0663_0019_0003$$$::ou uma arma limitada que derrota o inimigo com sua habilidade Ășnica?[lr]::
72195::$$$message_0663_0019_0004$$$::...PorĂ©m.[lr]::
72196::$$$message_0663_0019_0005$$$::NĂŁo importa qual seja, nada deve ser capaz de se igualar Ă  Matou Sakura.::
72197::$$$message_0663_0020_0000$$$::A diferenĂ§a entre a energia mĂĄgica delas Ă© muito grande.[lr]::
72198::$$$message_0663_0020_0001$$$::NĂŁo importa que tipo de taumaturgia seja, Matou Sakura conseguirĂĄ superar a magia sem fazer qualquer esforĂ§o.::
72199::$$$message_0663_0021_0000$$$::"O que foi, por que estĂĄ tremendo, Nee-san? ...Fufu, nĂŁo me diga que vocĂȘ perdeu a coragem de repente?"[lr]::
72200::$$$message_0663_0021_0001$$$::"...Falou bem. Onde estĂĄ o seu guardiĂŁo? VocĂȘ Ă© uma covarde, entĂŁo nĂŁo te preocupa o fato dele nĂŁo estar do seu lado?"[lr]::
72201::$$$message_0663_0021_0002$$$::"[w l=8][line8]"[lr]::
72202::$$$message_0663_0021_0003$$$::...O ar congela.[lr]::
72203::$$$message_0663_0021_0004$$$::Uma tensĂŁo hostil se mistura com o ar quente da caverna.::
72204::$$$message_0663_0022_0000$$$::"[w l=8][line8]"[lr]::
72205::$$$message_0663_0022_0001$$$::A garota de preto morde o lĂĄbio e suspira.[lr]::
72206::$$$message_0663_0022_0002$$$::"O VovĂŽ se foi. Ele era um incĂŽmodo, por isso eu o esmaguei junto com o Assassin."[lr]::
72207::$$$message_0663_0022_0003$$$::Ela sorri graciosamente.::
72208::$$$message_0663_0023_0000$$$::"......"[lr]::
72209::$$$message_0663_0023_0001$$$::Ela nĂŁo precisa perguntar.[lr]::
72210::$$$message_0663_0023_0002$$$::Matou Zouken foi morto por Matou Sakura.[lr]::
72211::$$$message_0663_0023_0003$$$::...Ă natural que ele nĂŁo tenha aparecido ainda.[lr]::
72212::$$$message_0663_0023_0004$$$::O velho foi comido pelo seu prĂłprio bichinho de estimaĂ§ĂŁo.::
72213::$$$message_0663_0024_0000$$$::"Entendo, entĂŁo vocĂȘ estĂĄ completamente livre. Zouken te prendia de uma maneira boa e ruim ao mesmo tempo.[lr]::
72214::$$$message_0663_0024_0001$$$::VocĂȘ nĂŁo tem nada a temer agora que vocĂȘ o matou."[lr]::
72215::$$$message_0663_0024_0002$$$::"NĂŁo exatamente. Ainda nĂŁo, Nee-san.[lr]::
72216::$$$message_0663_0024_0003$$$::Matar o meu avĂŽ nĂŁo foi o suficiente. Eu sou forte assim e posso fazer qualquer coisa, mas ainda estou presa."::
72217::$$$message_0663_0025_0000$$$::"...Poxa. Nee-san, vocĂȘ Ă© tĂŁo insignificante, mas vocĂȘ nĂŁo desaparece de dentro de mim. VocĂȘ ainda atormenta minha mente.[lr]::
72218::$$$message_0663_0025_0001$$$::EntĂŁo[w l=4][line4]enquanto vocĂȘ viver, nĂŁo poderei ser livre."::
72219::$$$message_0663_0026_0000$$$::Ela fala em um ritmo monĂłtono, mas suas palavras sĂŁo pesadas como lodo.[lr]::
72220::$$$message_0663_0026_0001$$$::A contradiĂ§ĂŁo prova a sua loucura.[lr]::
72221::$$$message_0663_0026_0002$$$::A hostilidade na caverna Ă© uma rapsĂłdia de superioridade e temor.::
72222::$$$message_0663_0027_0000$$$::"...Ah. Mas vocĂȘ parece feliz mesmo apesar disso. VocĂȘ matou o Zouken e o Assassin, entĂŁo suponho que tenha matado o Kirei tambĂ©m.[lr]::
72223::$$$message_0663_0027_0001$$$::Que bela atuaĂ§ĂŁo para alguĂ©m que odiava matar... estĂĄ ficando acostumada a assassinar agora?"::
72224::$$$message_0663_0028_0000$$$::"Sim. Esmagar pessoas e comĂȘ-las sĂŁo a mesma coisa.[lr]::
72225::$$$message_0663_0028_0001$$$::Para as pessoas, a vida Ă© entediante e sem sentido se vocĂȘ nĂŁo se divertir, e Ă© doloroso se vocĂȘ nĂŁo comer, nĂŁo Ă©?[lr]::
72226::$$$message_0663_0028_0002$$$::O mesmo vale pra mim. Eu sou igual a vocĂȘ. SĂł estou fazendo o que todo mundo faz."::
72227::$$$message_0663_0029_0000$$$::"[w l=3][line3]Espera. VocĂȘ estĂĄ mesmo levando a sĂ©rio essa lĂłgica distorcida?"[lr]::
72228::$$$message_0663_0029_0001$$$::"NĂŁo Ă© uma lĂłgica distorcida. Eu nĂŁo estou errada.[lr]::
72229::$$$message_0663_0029_0002$$$::Ă diferente porque eu fiquei forte. Eu sou forte, por isso sou diferente agora."::
72230::$$$message_0663_0030_0000$$$::"Eu[w l=4][line4]eu sou forte. Tudo serĂĄ perdoado se vocĂȘ for forte.[lr]::
72231::$$$message_0663_0030_0001$$$::...Sim. Se eu for forte e ninguĂ©m puder me derrotar, entĂŁo tudo o que eu fiz estarĂĄ perdoado. Se eu nĂŁo for eu mesma, entĂŁo nĂŁo hĂĄ como me culpar por tudo que eu fiz...!"::
72232::$$$message_0663_0031_0000$$$::Um grito de raiva.[lr]::
72233::$$$message_0663_0031_0001$$$::Ă a queixa de uma crianĂ§a insolente que nĂŁo pode escapar a menos que ela acredite nisso.::
72234::$$$message_0663_0032_0000$$$::"Agora vocĂȘ entende, Nee-san? Ă isso o que irei me tornar. Por isso que eu posso matar qualquer um. Ă natural para mim."[lr]::
72235::$$$message_0663_0032_0001$$$::"......Entendo. EntĂŁo vocĂȘ vai descontar em tudo o que vocĂȘ vĂȘ pela frente? Mas e o Shirou? Ele ainda acredita que pode te salvar. VocĂȘ vai matĂĄ-lo tambĂ©m?"::
72236::$$$message_0663_0033_0000$$$::"[w l=4][line4]!"[lr]::
72237::$$$message_0663_0033_0001$$$::A garota se endurece.[lr]::
72238::$$$message_0663_0033_0002$$$::A pergunta da Rin Ă© seu Ășltimo obstĂĄculo.[lr]::
72239::$$$message_0663_0033_0003$$$::...Seu entusiasmo diminui.[lr]::
72240::$$$message_0663_0033_0004$$$::Pensando sobre ele, ela recobra sua sanidade.::
72241::$$$message_0663_0034_0000$$$::Um sorriso sereno cruza o seu rosto.[lr]::
72242::$$$message_0663_0034_0001$$$::"Sim. Senpai nĂŁo Ă© exceĂ§ĂŁo.[lr]::
72243::$$$message_0663_0034_0002$$$::NĂŁo[w l=3][line3]ele Ă© o Ășnico que eu quero matar, Nee-san.[lr]::
72244::$$$message_0663_0034_0003$$$::...Sim. Eu quero rapidamente.[w l=4][line4]"::
72245::$$$message_0663_0035_0000$$$::[w l=4][line4]Engolir o Senpai tambĂ©m.::
72246::$$$message_0663_0036_0000$$$::"[w l=8][line8]"[lr]::
72247::$$$message_0663_0036_0001$$$::A resposta da Matou Sakura mostra que ela estĂĄ alĂ©m de qualquer ajuda.[lr]::
72248::$$$message_0663_0036_0002$$$::Rin segura firme a espada de jĂłias e mede a distĂąncia entre elas.::
72249::$$$message_0663_0037_0000$$$::"...Hmpf. E o que aconteceu com toda aquela conversa de levar o Angra Mainyu junto com vocĂȘ?[lr]::
72250::$$$message_0663_0037_0001$$$::Eu sabia que vocĂȘ era idiota, mas nĂŁo tĂŁo idiota assim. VocĂȘ se deixou ser engolida, e agora jĂĄ deixou de ser humana."[lr]::
72251::$$$message_0663_0037_0002$$$::Uma voz cheia de hostilidade.[lr]::
72252::$$$message_0663_0037_0003$$$::Como supervisora dessas terras, Tohsaka Rin reconhece sua prĂłpria irmĂŁ como o "mal".::
72253::$$$message_0663_0038_0000$$$::"[w l=4][line4]Fuh. VocĂȘ estĂĄ blefando. Por favor, seja honesta com si mesma, Nee-san.[lr]::
72254::$$$message_0663_0038_0001$$$::VocĂȘ tem inveja desse grande poder, nĂŁo Ă©? VocĂȘ estĂĄ com inveja, nĂŁo estĂĄ? Ă por isso que vocĂȘ veio me matar mesmo sabendo que nĂŁo irĂĄ conseguir.[lr]::
72255::$$$message_0663_0038_0002$$$::......Sim. VocĂȘ vai roubĂĄ-lo de mim para poder ficar com a felicidade sĂł para vocĂȘ."::
72256::$$$message_0663_0039_0000$$$::As sombras se levantam.[lr]::
72257::$$$message_0663_0039_0001$$$::Uma taumaturgia de absorĂ§ĂŁo, um amontoado de energia mĂĄgica que Ă© equivalente ao Fantasma Nobre de um Servo.[lr]::
72258::$$$message_0663_0039_0002$$$::NĂŁo apenas um, mas vĂĄrios se levantam para atacar.::
72259::$$$message_0663_0040_0000$$$::"NĂŁo vou te dar ele. Esse poder Ă© meu. Tudo o que eu vou te dar Ă© arrependimento e desespero.[lr]::
72260::$$$message_0663_0040_0001$$$::Vou lentamente te mostrar o que eu quero dizer."[lr]::
72261::$$$message_0663_0040_0002$$$::HĂĄ quatro figuras.[lr]::
72262::$$$message_0663_0040_0003$$$::Eles se aproximam da pequena pessoa entre eles como gigantes protegendo a garota.::
72263::$$$message_0663_0041_0000$$$::"[w l=4][line4]Irei te mostrar a diferenĂ§a entre os nossos poderes, Nee-san.[lr]::
72264::$$$message_0663_0041_0001$$$::NinguĂ©m virĂĄ te salvar dessa vez. VocĂȘ irĂĄ se afogar em mim como um inseto em um lago."[lr]::
72265::$$$message_0663_0041_0002$$$::As sombras imponentes atacam ela.[lr]::
72266::$$$message_0663_0041_0003$$$::Um poder titĂąnico que nĂŁo pode ser bloqueado ou esquivado engole Tohsaka Rin.::
ș