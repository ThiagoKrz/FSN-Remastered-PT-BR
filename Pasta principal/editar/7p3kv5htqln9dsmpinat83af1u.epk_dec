DAT
id=qid::label=str::text=lstr::
71732::$$$message_0659_0000_0000$$$::"[w l=4][line4], [w l=4][line4], [w l=4][line4]"[lr]::
71733::$$$message_0659_0000_0001$$$::Minha consciência está quebrando.::
71734::$$$message_0659_0001_0000$$$::"[w l=4][line4], [w l=4][line4], [w l=4][line4]"[lr]::
71735::$$$message_0659_0001_0001$$$::É só uma questão de tempo até a caverna desabar.[lr]::
71736::$$$message_0659_0001_0002$$$::O teto está desmoronando, e o chão está virando uma pilha de pedregulho.::
71737::$$$message_0659_0002_0000$$$::"[w l=4][line4], [w l=4][line4], [w l=4][line4]"[lr]::
71738::$$$message_0659_0002_0001$$$::Minhas juntas estão rígidas.[lr]::
71739::$$$message_0659_0002_0002$$$::Dói mover meus membros.[lr]::
71740::$$$message_0659_0002_0003$$$::Meus nervos estão quentes.[lr]::
71741::$$$message_0659_0002_0004$$$::Centenas de lâminas estão crescendo do meu corpo.[lr]::
71742::$$$message_0659_0002_0005$$$::Uma morte inescapável por perfuração.[lr]::
71743::$$$message_0659_0002_0006$$$::Seu corpo era feito de espadas.[lr]::
71744::$$$message_0659_0002_0007$$$::Eu já sabia disso.[lr]::
71745::$$$message_0659_0002_0008$$$::A bomba relógio foi ativada quando eu usei projeção.[lr]::
71746::$$$message_0659_0002_0009$$$::Esse fim já foi determinado.::
71747::$$$message_0659_0003_0000$$$::"[w l=4][line4]Ha, ah[w l=4][line4]!"[lr]::
71748::$$$message_0659_0003_0001$$$::Eu estou desmoronando.[lr]::
71749::$$$message_0659_0003_0002$$$::Eu vou me despedaçar se eu continuar.[lr]::
71750::$$$message_0659_0003_0003$$$::Eu vou me despedaçar, assim como várias pedras no chão.::
71751::$$$message_0659_0004_0000$$$::...Eu ainda vou conseguir.[lr]::
71752::$$$message_0659_0004_0001$$$::Meu corpo está morrendo, mas eu não vou me perder por mais um dia se eu parar agora.::
71753::$$$message_0659_0005_0000$$$::Somente um dia de prolongação de vida.[lr]::
71754::$$$message_0659_0005_0001$$$::Mas agora mesmo, eu amaria ter algo tão insignificante.[lr]::
71755::$$$message_0659_0005_0002$$$::Só um dia. Uma hora ou até um minuto.[lr]::
71756::$$$message_0659_0005_0003$$$::Se eu conseguir viver, eu quero ficar aqui o máximo possível, não importa o quão miserável seja.::
71757::$$$message_0659_0006_0000$$$::"Haa, gu[w l=4][line4]......!"[lr]::
71758::$$$message_0659_0006_0001$$$::Uma rachadura.[lr]::
71759::$$$message_0659_0006_0002$$$::Não fora, mas dentro. O núcleo accumbens no meu cérebro quebra.[lr]::
71760::$$$message_0659_0006_0003$$$::A parte que administra o príncipio do compuramento, a ligação ao prazer.[lr]::
71761::$$$message_0659_0006_0004$$$::A parte mais importante da vida. Vida é a busca por prazer; sem ele, humanos seriam bestas.::
71762::$$$message_0659_0007_0000$$$::"Haa, ah."[lr]::
71763::$$$message_0659_0007_0001$$$::Não é conveniente.[lr]::
71764::$$$message_0659_0007_0002$$$::Eu ainda quero.[lr]::
71765::$$$message_0659_0007_0003$$$::Eu ainda quero manter minha memória pelo máximo de tempo possível.[lr]::
71766::$$$message_0659_0007_0004$$$::Mas está desintegrando.[lr]::
71767::$$$message_0659_0007_0005$$$::A dor da perda não impede minhas memórias de desaparecerem.::
71768::$$$message_0659_0008_0000$$$::Eu desapareço quanto mais eu caminho.[lr]::
71769::$$$message_0659_0008_0001$$$::Eu não vou conseguir.[lr]::
71770::$$$message_0659_0008_0002$$$::Mesmo que eu consiga chegar, eu provavelmente não vou me lembrar do que tenho que fazer.[lr]::
71771::$$$message_0659_0008_0003$$$::Então eu deveria parar aqui e esperar por ajuda[w l=4][line4]::
71772::$$$message_0659_0009_0000$$$::"[w l=4][line4]Sim, eu me lembro."[lr]::
71773::$$$message_0659_0009_0001$$$::Mas.[lr]::
71774::$$$message_0659_0009_0002$$$::Em algum lugar do meu corpo, há uma grande razão.[lr]::
71775::$$$message_0659_0009_0003$$$::"Sakura[w l=4][line4]vamos ver as flores."[lr]::
71776::$$$message_0659_0009_0004$$$::Então eu tenho que cumprir meu papel.::
71777::$$$message_0659_0010_0000$$$::[w l=4][line4]O tempo parou.[lr]::
71778::$$$message_0659_0010_0001$$$::Não há dor.[lr]::
71779::$$$message_0659_0010_0002$$$::Eu estou demorando um dia inteiro para dar um único passo.::
71780::$$$message_0659_0010_0003$$$::[w l=4][line4]Eu esqueço de respirar.[lr]::
71781::$$$message_0659_0010_0004$$$::Não há dor.[lr]::
71782::$$$message_0659_0010_0005$$$::Eu não conseguiria respirar nem se tivesse um dia inteiro para isso.::
71783::$$$message_0659_0010_0006$$$::[w l=4][line4]Eu perco o significado.[lr]::
71784::$$$message_0659_0010_0007$$$::O que era dor?[lr]::
71785::$$$message_0659_0010_0008$$$::Material orgânico vira uma substância inorgânica.::
71786::$$$message_0659_0010_0009$$$::Eu consigo me manter.[lr]::
71787::$$$message_0659_0010_0010$$$::Eu me encosto na parede para evitar cair.[lr]::
71788::$$$message_0659_0010_0011$$$::Todos os pedaços da minha existência são apoiados em um único suporte.[lr]::
71789::$$$message_0659_0010_0012$$$::Não há como o suporte me apoiar.[lr]::
71790::$$$message_0659_0010_0013$$$::O suporte quebra.::
71791::$$$message_0659_0011_0000$$$::Não há princípio de comportamento.[lr]::
71792::$$$message_0659_0011_0001$$$::Não há sentido no comportamento.[lr]::
71793::$$$message_0659_0011_0002$$$::Não há sentido na existência.[lr]::
71794::$$$message_0659_0011_0003$$$::Eu não sinto medo.[lr]::
71795::$$$message_0659_0011_0004$$$::O significado por trás da minha existência desaparece.::
71796::$$$message_0659_0012_0000$$$::Eu não estou mais vivo.[lr]::
71797::$$$message_0659_0012_0001$$$::Meus braços não se movem mais.::
71798::$$$message_0659_0013_0000$$$::"[w l=4][line4]Trace."[lr]::
71799::$$$message_0659_0013_0001$$$::Palavras saem da minha boca.[lr]::
71800::$$$message_0659_0013_0002$$$::Tem algo ainda restando mesmo após a linguagem, neopálio, e cérebro serem perdidos.::
71801::$$$message_0659_0014_0000$$$::"[w l=4][line4]On."[lr]::
71802::$$$message_0659_0014_0001$$$::O corpo morre.[lr]::
71803::$$$message_0659_0014_0002$$$::Mas a alma permanece.::
71804::$$$message_0659_0015_0000$$$::Girando os oito versos.[lr]::
71805::$$$message_0659_0015_0001$$$::A carga é transmitida do corpo a alma, e mais significado é[lr]::
71806::$$$message_0659_0015_0002$$$::"[w l=8][line8]Ah."[lr]::
71807::$$$message_0659_0015_0003$$$::E Emiya Shirou morre.[lr]::
71808::$$$message_0659_0015_0004$$$::A figura parada não é diferente de uma máquina.[lr]::
71809::$$$message_0659_0015_0005$$$::Ela é programada para balançar a espada, mas é um cadáver sem desejo de se mover.::
71810::$$$message_0659_0016_0000$$$::Mas mesmo sem inteligência humana...[lr]::
71811::$$$message_0659_0016_0001$$$::Existem máquinas que tecem vários sonhos nesse mundo.::
71812::$$$message_0659_0017_0000$$$::Havia uma promessa.[lr]::
71813::$$$message_0659_0017_0001$$$::Assim que o inverno acabar, quando a primavera chegar[w l=4][line4]::
71814::$$$message_0659_0018_0000$$$::Uma recitação de palavras sem significado.[lr]::
71815::$$$message_0659_0018_0001$$$::Uma pequena esperança que eu lembrei até o fim.::

