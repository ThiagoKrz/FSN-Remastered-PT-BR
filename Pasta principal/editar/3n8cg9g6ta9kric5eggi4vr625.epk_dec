DAT
id=qid::label=str::text=lstr::
35332::$$$message_0289_0000_0000$$$::"Três[line3]qual a sua resposta, Emiya-kun?"[lr]::
35333::$$$message_0289_0000_0001$$$::"[line6]!?"[lr]::
35334::$$$message_0289_0000_0002$$$::Nós nos encaramos.[lr]::
35335::$$$message_0289_0000_0003$$$::Esse grito veio de baixo...!?::
35336::$$$message_0289_0001_0000$$$::"Tohsaka, isso foi..."[lr]::
35337::$$$message_0289_0001_0001$$$::"...Um grito."[lr]::
35338::$$$message_0289_0001_0002$$$::Eu instantaneamente me levanto e começo a correr.[lr]::
35339::$$$message_0289_0001_0003$$$::"Ei, você sabe de onde que ele veio, Emiya-kun!?"[lr]::
35340::$$$message_0289_0001_0004$$$::"Não! Eu só sei que veio de baixo da gente!"[lr]::
35341::$$$message_0289_0001_0005$$$::"Espera, eu vou parar o Campo Limitado agora[line4]!"::
35342::$$$message_0289_0002_0000$$$::Eu desço as escadas correndo.[lr]::
35343::$$$message_0289_0002_0001$$$::"Espera! É perigoso ir sozinho!"[lr]::
35344::$$$message_0289_0002_0002$$$::"Não é a hora de ficar preocupado! Esse grito foi incomum!"::
35345::$$$message_0289_0003_0000$$$::"Eu sei! É por isso que eu tô dizendo que é perigoso!"[lr]::
35346::$$$message_0289_0003_0001$$$::Nós descemos até o primeiro andar.[lr]::
35347::$$$message_0289_0003_0002$$$::Não tem ninguém se movendo no corredor.[lr]::
35348::$$$message_0289_0003_0003$$$::Mas tem uma estudante caída deitada ali.::
35349::$$$message_0289_0004_0000$$$::"[line4]!"[lr]::
35350::$$$message_0289_0004_0001$$$::A estudante tá caída na frente da saída de emergência.::
35351::$$$message_0289_0005_0000$$$::"...Ótimo. Ela só tá inconsciente."[lr]::
35352::$$$message_0289_0005_0001$$$::Eu checo a estudante.[lr]::
35353::$$$message_0289_0005_0002$$$::Ela deve ser do primeiro ano.[lr]::
35354::$$$message_0289_0005_0003$$$::Ela tá inconsciente, mas eu não vejo feridas, então ela deve ficar bem.::
35355::$$$message_0289_0006_0000$$$::"Você tá errado[line3]! Ela tá tão pálida! Você não consegue perceber que ela tá vazia por dentro!?"[lr]::
35356::$$$message_0289_0006_0001$$$::"Huh...? Vazia por dentro...?"::
35357::$$$message_0289_0007_0000$$$::"Ela teve sua energia mágica, não, sua energia vital pra ser mais precisa, drenada. Isso é tão ruim, não, pior que as pessoas que foram atacadas pela Caster.[lr]::
35358::$$$message_0289_0007_0001$$$::[line3]Ela vai morrer se a gente deixar ela."[lr]::
35359::$$$message_0289_0007_0002$$$::"Morrer!? Mesmo que ela não tenha nenhuma ferida!?"::
35360::$$$message_0289_0008_0000$$$::"Ei espera. É natural alguém morrer se essa pessoa estiver vazia por dentro mesmo que não tenha feridas externas. ...Espera, eu acho que consigo fazer algo com a pedra que eu tenho[line4]"::
35361::$$$message_0289_0009_0000$$$::Ela procura no seu bolso.[lr]::
35362::$$$message_0289_0009_0001$$$::...Graças a Deus.[lr]::
35363::$$$message_0289_0009_0002$$$::Parece sério, mas a Tohsaka parece saber como curar ela.::
35364::$$$message_0289_0010_0000$$$::A Tohsaka se agacha e olha pra estudante.[lr]::
35365::$$$message_0289_0010_0001$$$::"[line8]"[lr]::
35366::$$$message_0289_0010_0002$$$::O rosto dela parece nervoso.[lr]::
35367::$$$message_0289_0010_0003$$$::Ela tende a estudante enquanto suor se forma na testa dela.::
35368::$$$message_0289_0011_0000$$$::"......?"[lr]::
35369::$$$message_0289_0011_0001$$$::...O que tá acontecendo?[lr]::
35370::$$$message_0289_0011_0002$$$::Esse rosto sério dela...[lr]::
35371::$$$message_0289_0011_0003$$$::Eu acho que vi ele recentemente[line4]::
35372::$$$message_0289_0012_0000$$$::"Aargh, é tão irritante...! Você pode fechar a porta, Emiya-kun!? O vento tá mexendo meu cabelo."[lr]::
35373::$$$message_0289_0012_0001$$$::"Huh[line4]ah, a saída de emergência?"[lr]::
35374::$$$message_0289_0012_0002$$$::Eu olho pra saída de emergência aberta.::
35375::$$$message_0289_0013_0000$$$::"Huh[line4]?"[lr]::
35376::$$$message_0289_0013_0001$$$::Aberta...?[lr]::
35377::$$$message_0289_0013_0002$$$::Pensando nisso agora, a gente ainda não sabe porque essa garota ta inconsciente.[lr]::
35378::$$$message_0289_0013_0003$$$::Ela não fez isso sozinha, então alguém deve ter atacado ela.[lr]::
35379::$$$message_0289_0013_0004$$$::Nós corremos pra cá assim que ouvimos o grito, então a saída de emergência é o único lugar por onde fugir.::
35380::$$$message_0289_0014_0000$$$::"[line4]Ah."[lr]::
35381::$$$message_0289_0014_0001$$$::É porque eu tava olhando pra saída de emergência?[lr]::
35382::$$$message_0289_0014_0002$$$::Eu sinto "algo" preto sendo atirado e eu-::
35383::$$$message_0289_0014_0003$$$::"Cuidado, Tohsaka!"[lr]::
35384::$$$message_0289_0014_0004$$$::...Eu protejo a Tohsaka com meu braço direito.::
35385::$$$message_0289_0015_0000$$$::"Huh[line3]o-o que é isso...!? Emiya-kun, s-seu braço...!"[lr]::
35386::$$$message_0289_0015_0001$$$::"[line8]!"[lr]::
35387::$$$message_0289_0015_0002$$$::Assim como a Tohsaka disse, uma adaga preta tá perfurando meu braço direito.::
35388::$$$message_0289_0016_0000$$$::A coisa se firmou entre meu pulso e meu braço parece um prego.[lr]::
35389::$$$message_0289_0016_0001$$$::Não, é muito grande pra chamar de prego.[lr]::
35390::$$$message_0289_0016_0002$$$::Algo como uma adaga perfurou meu braço.::
35391::$$$message_0289_0017_0000$$$::"Por que[line3]não, você tá sangrando muito. Isso não dói...?"[lr]::
35392::$$$message_0289_0017_0001$$$::"Dói. Dói muito."[lr]::
35393::$$$message_0289_0017_0002$$$::Mas dói tanto que eu não consigo entrar em pânico.[lr]::
35394::$$$message_0289_0017_0003$$$::Mas além disso...[lr]::
35395::$$$message_0289_0017_0004$$$::Alguém jogou isso no rosto da Tohsaka?::
35396::$$$message_0289_0018_0000$$$::"[line4]Por favor cuida dela, Tohsaka."[lr]::
35397::$$$message_0289_0018_0001$$$::Eu começo a correr.[lr]::
35398::$$$message_0289_0018_0002$$$::Eu não tenho tempo pra esperar pela resposta da Tohsaka.[lr]::
35399::$$$message_0289_0018_0003$$$::Eu aperto o cano de metal "fortalecido" na minha mão esquerda e corro pra fora da saída de emergência.::
35400::$$$message_0289_0019_0000$$$::"Fuh[line4]fuu, fuu, fu[line3]"[lr]::
35401::$$$message_0289_0019_0001$$$::Eu corro com meu braço direito balançando.[lr]::
35402::$$$message_0289_0019_0002$$$::O braço tá vermelho abaixo do meu cotovelo.[lr]::
35403::$$$message_0289_0019_0003$$$::...Tem algum tipo de má sorte com meus braços hoje?[lr]::
35404::$$$message_0289_0019_0004$$$::A Tohsaka me disse pra dar pra ela meu selo de comando do meu braço esquerdo e agora esse quase foi rasgado.::
35405::$$$message_0289_0020_0000$$$::"[line4]Tem que estar por aqui."[lr]::
35406::$$$message_0289_0020_0001$$$::Eu olho ao redor.[lr]::
35407::$$$message_0289_0020_0002$$$::Eu não sei o que eu tô sentindo, mas eu certamente sinto.[lr]::
35408::$$$message_0289_0020_0003$$$::A "pessoa" que atacou aquela estudante,[lr]::
35409::$$$message_0289_0020_0004$$$::a "pessoa" que atacou a Tohsaka com aquela adaga tá próxima.[lr]::
35410::$$$message_0289_0020_0005$$$::A pessoa ainda tá por aqui.[lr]::
35411::$$$message_0289_0020_0006$$$::Se eu fechar meus olhos, eu consigo sentir energia mágica negra se movendo.::
35412::$$$message_0289_0021_0000$$$::"Atrás do estande de arco e flecha[line4]na floresta..!"[lr]::
35413::$$$message_0289_0021_0001$$$::Eu pulo a cerca e corro pela terra mofada.[lr]::
35414::$$$message_0289_0021_0002$$$::[line4]Então.[lr]::
35415::$$$message_0289_0021_0003$$$::Entre as árvores...[lr]::
35416::$$$message_0289_0021_0004$$$::Alguém que eu reconheço tá parado lá, sorrindo.::
35417::$$$message_0289_0022_0000$$$::"Shinji...?"[lr]::
35418::$$$message_0289_0022_0001$$$::Eu paro.[lr]::
35419::$$$message_0289_0022_0002$$$::Por que o Shinji tá aqui?[lr]::
35420::$$$message_0289_0022_0003$$$::Ele tá desaparecido agora mesmo...[lr]::
35421::$$$message_0289_0022_0004$$$::Não, a Mitsuzuri é quem tá desaparecida, o Shinji é o último que viu ela, e[line4]::
35422::$$$message_0289_0023_0000$$$::"[line4]!!!!!"[lr]::
35423::$$$message_0289_0023_0001$$$::O braço ferido treme.[lr]::
35424::$$$message_0289_0023_0002$$$::No instante que eu caio no chão...[lr]::
35425::$$$message_0289_0023_0003$$$::Uma adaga como um prego é impulsionada até minha garganta.::
35426::$$$message_0289_0024_0000$$$::"......!"[lr]::
35427::$$$message_0289_0024_0001$$$::Eu instantaneamente desvio.[lr]::
35428::$$$message_0289_0024_0002$$$::Eu só continuo caindo e continuo rolando pra frente pra evitar isso.::
35429::$$$message_0289_0025_0000$$$::"Ha[line4]guh......!!!!"[lr]::
35430::$$$message_0289_0025_0001$$$::Minha garganta.[lr]::
35431::$$$message_0289_0025_0002$$$::Tá arranhada e a pele cortada.[lr]::
35432::$$$message_0289_0025_0003$$$::Mas isso é meio fortuno.[lr]::
35433::$$$message_0289_0025_0004$$$::Se eu tivesse me atrasado por um segundo, teria sido minha garganta que seria cortada.::
35434::$$$message_0289_0026_0000$$$::"Você...!"[lr]::
35435::$$$message_0289_0026_0001$$$::Eu instantaneamente me levanto.[lr]::
35436::$$$message_0289_0026_0002$$$::Na frente dela...[lr]::
35437::$$$message_0289_0026_0003$$$::...Está uma mulher em preto com um sorriso irritante.::
35438::$$$message_0289_0027_0000$$$::"Um servo...!"[lr]::
35439::$$$message_0289_0027_0001$$$::Eu tenho certeza disso.[lr]::
35440::$$$message_0289_0027_0002$$$::Uma concentração de energia mágica que nem a Tohsaka aguentaria.[lr]::
35441::$$$message_0289_0027_0003$$$::Uma beleza etérea e o grosso cheiro de sangue.[lr]::
35442::$$$message_0289_0028_0000$$$::"Ela desapareceu...!?"[lr]::
35443::$$$message_0289_0028_0001$$$::A sombra escura desaparece da minha visão.[lr]::
35444::$$$message_0289_0028_0002$$$::[line4]Meus instintos me dizem que vou ser morto.[lr]::
35445::$$$message_0289_0028_0003$$$::Eu desesperadamente balanço minha arma em cima de mim.::
35446::$$$message_0289_0029_0000$$$::"Guh[line4]!!"[lr]::
35447::$$$message_0289_0029_0001$$$::Eu paro o "prego" vindo até minha cabeça.[lr]::
35448::$$$message_0289_0029_0002$$$::Ela é como uma aranha, pulando pela floresta como se estivesse grudando nas árvores.::
35449::$$$message_0289_0030_0000$$$::"[line8]"[lr]::
35450::$$$message_0289_0030_0001$$$::Eu corro.[lr]::
35451::$$$message_0289_0030_0002$$$::Foi só pura coincidência que eu consegui bloquear aquele ataque surpresa.[lr]::
35452::$$$message_0289_0030_0003$$$::Eu não consigo bloquear outro ataque, e não tem como eu conseguir fugir.::
35453::$$$message_0289_0031_0000$$$::"Haa[line4]!"[lr]::
35454::$$$message_0289_0031_0001$$$::Eu corro até uma árvore próxima e encosto minhas costas nela.[lr]::
35455::$$$message_0289_0031_0002$$$::Eu devo ser capaz de bloquear quaisquer ataques que venham por trás de mim agora. Não, eu tenho que acreditar que eu consigo.::
35456::$$$message_0289_0032_0000$$$::"Droga[line4]a figura dela chama muita atenção, então[line4]"[lr]::
35457::$$$message_0289_0032_0001$$$::Eu não vejo o Servo em preto em nenhum lugar.[lr]::
35458::$$$message_0289_0032_0002$$$::Ela pode estar pulando de galho em galho, já que eu não vejo ela descendo.::
35459::$$$message_0289_0033_0000$$$::"[line8]"[lr]::
35460::$$$message_0289_0033_0001$$$::Suor rola pela minha testa.[lr]::
35461::$$$message_0289_0033_0002$$$::O som das correntes é como o de uma cobra mirando sua presa.::
35462::$$$message_0289_0034_0000$$$::"Ha[line4]Haha, ha."[lr]::
35463::$$$message_0289_0034_0001$$$::Eu suprimo a risada tentando me escapar.[lr]::
35464::$$$message_0289_0034_0002$$$::O som das correntes ecoa pela floresta.[lr]::
35465::$$$message_0289_0034_0003$$$::Mesmo que eu possa ser morto no próximo momento, minha mente tá completamente vazia.[lr]::
35466::$$$message_0289_0034_0004$$$::Eu não tenho nenhuma noção de tempo, e a guilhotina não tá descendo.::
35467::$$$message_0289_0035_0000$$$::"Ha[line4]Ha, ha."[lr]::
35468::$$$message_0289_0035_0001$$$::É isso que é estranho.[lr]::
35469::$$$message_0289_0035_0002$$$::A batalha já deveria ter acabado.::
35470::$$$message_0289_0036_0000$$$::Mas eu ainda tô vivo.[lr]::
35471::$$$message_0289_0036_0001$$$::É tão estranho que eu penso que eu talvez tenha sido morto pelo último ataque e tô meramente sonhando agora.::
35472::$$$message_0289_0037_0000$$$::"[line4]Saber."[lr]::
35473::$$$message_0289_0037_0001$$$::...Eu não sou páreo pra um servo.[lr]::
35474::$$$message_0289_0037_0002$$$::Então eu tenho que depender dela.[lr]::
35475::$$$message_0289_0037_0003$$$::O selo de comando. Se eu usar o selo de comando pra chamar a Saber, eu devo ser capaz de escapar dessa situação.::
35476::$$$message_0289_0038_0000$$$::Mas[line4]tudo bem isso?[lr]::
35477::$$$message_0289_0038_0001$$$::Eu me coloquei nessa situação perigosa. Então, eu deveria ser responsável por isso, e acima de tudo[line4]::
35478::$$$message_0289_0039_0000$$$::"[line4]Eu não fiz tudo que eu consigo fazer."[lr]::
35479::$$$message_0289_0039_0001$$$::Isso mesmo.[lr]::
35480::$$$message_0289_0039_0002$$$::Eu tenho uma arma nas minhas mãos, mesmo que seja uma fraca.[lr]::
35481::$$$message_0289_0039_0003$$$::E meu corpo ainda consegue se mover.[lr]::
35482::$$$message_0289_0039_0004$$$::Se essa é uma posição ruim, eu só tenho que me mover.[lr]::
35483::$$$message_0289_0039_0005$$$::Eu posso chamar a Saber depois disso[line4]::
35484::$$$message_0289_0040_0000$$$::"Eu estou surpresa. Você não está usando seu selo de comando?"[lr]::
35485::$$$message_0289_0040_0001$$$::"[line4]!"[lr]::
35486::$$$message_0289_0040_0002$$$::A voz ecoa.[lr]::
35487::$$$message_0289_0040_0003$$$::Ela tá em cima de mim[line4]em um galho em algum lugar, como esperado.::
35488::$$$message_0289_0041_0000$$$::"...Heh. Infelizmente, eu não tenho muitos sobrando, então eu não sei o que eu vou fazer no futuro se eu usar algo assim."[lr]::
35489::$$$message_0289_0041_0001$$$::E bom, eu meio que não sei como usar ele.::
35490::$$$message_0289_0042_0000$$$::"...Entendo. Você deve ser corajoso ao contrário do meu mestre."[lr]::
35491::$$$message_0289_0042_0001$$$::Eu procuro ao meu redor.[lr]::
35492::$$$message_0289_0042_0002$$$::De onde que tá vindo essa voz[line4]?::
35493::$$$message_0289_0043_0000$$$::"Então eu irei alterar meu curso de ação. Eu não posso dar meu máximo contra um mestre sem seu servo[line3]Eu irei gentilmente lhe matar."[lr]::
35494::$$$message_0289_0043_0001$$$::...A voz para.[lr]::
35495::$$$message_0289_0043_0002$$$::O som das correntes é o único som ecoando pela floresta.::
35496::$$$message_0289_0044_0000$$$::"[line8]"[lr]::
35497::$$$message_0289_0044_0001$$$::Ela tá vindo.[lr]::
35498::$$$message_0289_0044_0002$$$::O que eu tenho que fazer é sair desse lugar.[lr]::
35499::$$$message_0289_0044_0003$$$::Pra fazer isso, eu teria que bloquear o "prego" dela algumas vezes.::
35500::$$$message_0289_0045_0000$$$::"......"[lr]::
35501::$$$message_0289_0045_0001$$$::O fato de que eu tenho que me defender usando a perna de uma cadeira é tão patético que é engraçado.[lr]::
35502::$$$message_0289_0045_0002$$$::Se eu pelo menos tivesse[line4][lr]::
35503::$$$message_0289_0045_0003$$$::Se essa vareta fosse tão esplêndida quanto as armas que ele tem, eu talvez conseguiria até contra-atacar.::
35504::$$$message_0289_0046_0000$$$::"[line22][r]::
35505::$$$message_0289_0046_0001$$$::[line22][r]::
35506::$$$message_0289_0046_0002$$$::[line13]Aqui vou eu."[lr]::
35507::$$$message_0289_0046_0003$$$::...Eu não tenho tempo pra pensar em e se.[lr]::
35508::$$$message_0289_0046_0004$$$::Tem por volta de 30 metros até a saída da floresta.[lr]::
35509::$$$message_0289_0046_0005$$$::Isso não é muito comparado a perseguição que eu tive com a [r]Tohsaka[line4]!::
35510::$$$message_0289_0047_0000$$$::[line4]Eu corro.[lr]::
35511::$$$message_0289_0047_0001$$$::Eu ignoro o som irritante das corrente e corro freneticamente até a saída...!::
35512::$$$message_0289_0048_0000$$$::"Fuh[line4]!"[lr]::
35513::$$$message_0289_0048_0001$$$::Eu repeli o ataque de cima.[lr]::
35514::$$$message_0289_0048_0002$$$::E então, usando a arma, eu bloqueio o chute circular executado pelo servo.[lr]::
35515::$$$message_0289_0048_0003$$$::Ela tá na minha frente agora.[lr]::
35516::$$$message_0289_0048_0004$$$::Eu repeli os ataques dela[line4]!::
35517::$$$message_0289_0049_0000$$$::"Sem chance[line4]!?"[lr]::
35518::$$$message_0289_0049_0001$$$::O servo de preto recua.::
35519::$$$message_0289_0050_0000$$$::"[line8]"[lr]::
35520::$$$message_0289_0050_0001$$$::É só uma coincidência.[lr]::
35521::$$$message_0289_0050_0002$$$::Se o primeiro ataque foi bloqueado por coincidência, esses ataques também foram bloqueados por chance.[lr]::
35522::$$$message_0289_0050_0003$$$::Eu não consigo nem ver os movimentos dela.[lr]::
35523::$$$message_0289_0050_0004$$$::Eu ficar vivo mesmo assim não é nada além de pura sorte.::
35524::$$$message_0289_0051_0000$$$::[line4]Mas.[lr]::
35525::$$$message_0289_0051_0001$$$::Coincidências são algo que continuam dessa forma?[lr]::
35526::$$$message_0289_0051_0002$$$::Não, e se minhas premissas tiverem erradas?[lr]::
35527::$$$message_0289_0051_0003$$$::O primeiro ataque.[lr]::
35528::$$$message_0289_0051_0004$$$::O ataque surpresa na minha cabeça.[lr]::
35529::$$$message_0289_0051_0005$$$::Emiya Shirou não conseguiria bloquear ataques assim.[lr]::
35530::$$$message_0289_0051_0006$$$::Eu não consigo bloquear eles por coincidência[line4]::
35531::$$$message_0289_0052_0000$$$::"[line4]Você..."[lr]::
35532::$$$message_0289_0052_0001$$$::O servo de preto murmura.[lr]::
35533::$$$message_0289_0052_0002$$$::A voz irritada dela é surpreendentemente bonita.::
35534::$$$message_0289_0053_0000$$$::"Hah, você não é nem um pouco boa. Você não é tão boa quanto os outros servos!"[lr]::
35535::$$$message_0289_0053_0001$$$::Eu balanço contra o servo na minha frente.[lr]::
35536::$$$message_0289_0053_0002$$$::"......!"[lr]::
35537::$$$message_0289_0053_0003$$$::O servo em preto bloqueia meu golpe e recua.::
35538::$$$message_0289_0054_0000$$$::"Eu consigo[line4]!"[lr]::
35539::$$$message_0289_0054_0001$$$::Não tem nada no meu caminho agora.[lr]::
35540::$$$message_0289_0054_0002$$$::O servo de preto recuou.[lr]::
35541::$$$message_0289_0054_0003$$$::Agora, tudo que eu tenho que fazer é ir mais alguns metros e[line4]::
35542::$$$message_0289_0055_0000$$$::"[line3]Não, aqui é o mais longe que você pode ir.[lr]::
35543::$$$message_0289_0055_0001$$$::Você já foi capturado."::
35544::$$$message_0289_0056_0000$$$::"Huh[line4]?"[lr]::
35545::$$$message_0289_0056_0001$$$::Meu corpo cai.[lr]::
35546::$$$message_0289_0056_0002$$$::Na verdade, eu tô sendo puxado pra trás.[lr]::
35547::$$$message_0289_0056_0003$$$::Meu braço direito dói.[lr]::
35548::$$$message_0289_0056_0004$$$::O braço perfurado tá sendo puxado por alguma força[line4]!?::
35549::$$$message_0289_0057_0000$$$::"Você ainda não entendeu? Essa coisa no seu braço é meu prego."[lr]::
35550::$$$message_0289_0057_0001$$$::"Seu prego[line4]"::
35551::$$$message_0289_0058_0000$$$::Isso me faz perceber.[lr]::
35552::$$$message_0289_0058_0001$$$::A coisa estendendo da arma dela.[lr]::
35553::$$$message_0289_0058_0002$$$::O som irritante de correntes.[lr]::
35554::$$$message_0289_0058_0003$$$::O som de correntes se movendo.[lr]::
35555::$$$message_0289_0058_0004$$$::O som das correntes amarradas que eu ouvi desde quando sai do prédio[line3]::
35556::$$$message_0289_0059_0000$$$::"Merda[line4]!"[lr]::
35557::$$$message_0289_0059_0001$$$::Eu estico meu braço esquerdo até meu braço direito, mas é tarde demais.[lr]::
35558::$$$message_0289_0059_0002$$$::O braço se move sozinho e é levantado.::
35559::$$$message_0289_0060_0000$$$::"Guh...! Agh[line4]!"[lr]::
35560::$$$message_0289_0060_0001$$$::Meu braço tá prestes a ser rasgado.[lr]::
35561::$$$message_0289_0060_0002$$$::O prego no meu braço direito.[lr]::
35562::$$$message_0289_0060_0003$$$::A corrente saindo dele me envolve no ar usando um pedaço como fulcro.::
35563::$$$message_0289_0061_0000$$$::"Ah[line4]guh[line4]......!"[lr]::
35564::$$$message_0289_0061_0001$$$::"...Bom. Parece que você estava dizendo algo bem interessante."[lr]::
35565::$$$message_0289_0061_0002$$$::O servo de preto se aproxima.[lr]::
35566::$$$message_0289_0061_0003$$$::Eu não consigo fugir ou lutar agora que eu tô suspenso no ar.::
35567::$$$message_0289_0062_0000$$$::"Você disse que eu sou inferior aos outros servos?[lr]::
35568::$$$message_0289_0062_0001$$$::...Isso é problemático. Eu não posso lhe matar a não ser que eu corrija esse engano seu."[lr]::
35569::$$$message_0289_0062_0002$$$::...Eu sou como um sacrifício.[lr]::
35570::$$$message_0289_0062_0003$$$::É como aqueles colocados em um filme ocidental.::
35571::$$$message_0289_0063_0000$$$::A adaga parecida com um prego é levantada.[lr]::
35572::$$$message_0289_0063_0001$$$::O servo de preto lambe a ponta dela.[lr]::
35573::$$$message_0289_0063_0002$$$::"Deixe me ver. Eu irei tomar estes olhos enganados seus.[lr]::
35574::$$$message_0289_0063_0003$$$::Eu irei tomar seus membros restantes depois disso."[lr]::
35575::$$$message_0289_0063_0004$$$::Ela pula levemente e aparece na frente de mim, que está suspenso três metros acima do chão.::
35576::$$$message_0289_0064_0000$$$::"[line8]"[lr]::
35577::$$$message_0289_0064_0001$$$::O prego vem até mim.[lr]::
35578::$$$message_0289_0064_0002$$$::Meu corpo ainda se move.[lr]::
35579::$$$message_0289_0064_0003$$$::Eu[line3][lr]::

