DAT
id=qid::label=str::text=lstr::
35332::$$$message_0289_0000_0000$$$::"TrΟΣs[line3]qual a sua resposta, Emiya-kun?"[lr]::
35333::$$$message_0289_0000_0001$$$::"[line6]!?"[lr]::
35334::$$$message_0289_0000_0002$$$::NΟ≥s nos encaramos.[lr]::
35335::$$$message_0289_0000_0003$$$::Esse grito veio de baixo...!?::
35336::$$$message_0289_0001_0000$$$::"Tohsaka, isso foi..."[lr]::
35337::$$$message_0289_0001_0001$$$::"...Um grito."[lr]::
35338::$$$message_0289_0001_0002$$$::Eu instantaneamente me levanto e comeΟßo a correr.[lr]::
35339::$$$message_0289_0001_0003$$$::"Ei, vocΟΣ sabe de onde que ele veio, Emiya-kun!?"[lr]::
35340::$$$message_0289_0001_0004$$$::"NΟΘo! Eu sΟ≥ sei que veio de baixo da gente!"[lr]::
35341::$$$message_0289_0001_0005$$$::"Espera, eu vou parar o campo de separaΟßΟΘo agora[line4]!"::
35342::$$$message_0289_0002_0000$$$::Eu desΟßo as escadas correndo.[lr]::
35343::$$$message_0289_0002_0001$$$::"Espera! Οâ perigoso ir sozinho!"[lr]::
35344::$$$message_0289_0002_0002$$$::"NΟΘo Ο© a hora de ficar preocupado! Esse grito foi incomum!"::
35345::$$$message_0289_0003_0000$$$::"Eu sei! Οâ por isso que eu tΟ¥ dizendo que Ο© perigoso!"[lr]::
35346::$$$message_0289_0003_0001$$$::NΟ≥s descemos atΟ© o primeiro andar.[lr]::
35347::$$$message_0289_0003_0002$$$::NΟΘo tem ninguΟ©m se movendo no corredor.[lr]::
35348::$$$message_0289_0003_0003$$$::Mas tem uma estudante caΟ≠da deitada ali.::
35349::$$$message_0289_0004_0000$$$::"[line4]!"[lr]::
35350::$$$message_0289_0004_0001$$$::A estudante tΟΓ caΟ≠da na frente da saΟ≠da de emergΟΣncia.::
35351::$$$message_0289_0005_0000$$$::"...Ο™timo. Ela sΟ≥ tΟΓ inconsciente."[lr]::
35352::$$$message_0289_0005_0001$$$::Eu checo a estudante.[lr]::
35353::$$$message_0289_0005_0002$$$::Ela deve ser do primeiro ano.[lr]::
35354::$$$message_0289_0005_0003$$$::Ela tΟΓ inconsciente, mas eu nΟΘo vejo feridas, entΟΘo ela deve ficar bem.::
35355::$$$message_0289_0006_0000$$$::"VocΟΣ tΟΓ errado[line3]! Ela tΟΓ tΟΘo pΟΓlida! VocΟΣ nΟΘo consegue perceber que ela tΟΓ vazia por dentro!?"[lr]::
35356::$$$message_0289_0006_0001$$$::"Huh...? Vazia por dentro...?"::
35357::$$$message_0289_0007_0000$$$::"Ela teve sua energia mΟΓgica, nΟΘo, sua energia vital pra ser mais precisa, drenada. Isso Ο© tΟΘo ruim, nΟΘo, pior que as pessoas que foram atacadas pela Caster.[lr]::
35358::$$$message_0289_0007_0001$$$::[line3]Ela vai morrer se a gente deixar ela."[lr]::
35359::$$$message_0289_0007_0002$$$::"Morrer!? Mesmo que ela nΟΘo tenha nenhuma ferida!?"::
35360::$$$message_0289_0008_0000$$$::"Ei espera. Οâ natural alguΟ©m morrer se essa pessoa estiver vazia por dentro mesmo que nΟΘo tenha feridas externas. ...Espera, eu acho que consigo fazer algo com a pedra que eu tenho[line4]"::
35361::$$$message_0289_0009_0000$$$::Ela procura no seu bolso.[lr]::
35362::$$$message_0289_0009_0001$$$::...GraΟßas a Deus.[lr]::
35363::$$$message_0289_0009_0002$$$::Parece sΟ©rio, mas a Tohsaka parece saber como curar ela.::
35364::$$$message_0289_0010_0000$$$::A Tohsaka se agacha e olha pra estudante.[lr]::
35365::$$$message_0289_0010_0001$$$::"[line8]"[lr]::
35366::$$$message_0289_0010_0002$$$::O rosto dela parece nervoso.[lr]::
35367::$$$message_0289_0010_0003$$$::Ela tende a estudante enquanto suor se forma na testa dela.::
35368::$$$message_0289_0011_0000$$$::"......?"[lr]::
35369::$$$message_0289_0011_0001$$$::...O que tΟΓ acontecendo?[lr]::
35370::$$$message_0289_0011_0002$$$::Esse rosto sΟ©rio dela...[lr]::
35371::$$$message_0289_0011_0003$$$::Eu acho que vi ele recentemente[line4]::
35372::$$$message_0289_0012_0000$$$::"Aargh, Ο© tΟΘo irritante...! VocΟΣ pode fechar a porta, Emiya-kun!? O vento tΟΓ mexendo meu cabelo."[lr]::
35373::$$$message_0289_0012_0001$$$::"Huh[line4]ah, a saΟ≠da de emergΟΣncia?"[lr]::
35374::$$$message_0289_0012_0002$$$::Eu olho pra saΟ≠da de emergΟΣncia aberta.::
35375::$$$message_0289_0013_0000$$$::"Huh[line4]?"[lr]::
35376::$$$message_0289_0013_0001$$$::Aberta...?[lr]::
35377::$$$message_0289_0013_0002$$$::Pensando nisso agora, a gente ainda nΟΘo sabe porque essa garota ta inconsciente.[lr]::
35378::$$$message_0289_0013_0003$$$::Ela nΟΘo fez isso sozinha, entΟΘo alguΟ©m deve ter atacado ela.[lr]::
35379::$$$message_0289_0013_0004$$$::NΟ≥s corremos pra cΟΓ assim que ouvimos o grito, entΟΘo a saΟ≠da de emergΟΣncia Ο© o ΟΚnico lugar por onde fugir.::
35380::$$$message_0289_0014_0000$$$::"[line4]Ah."[lr]::
35381::$$$message_0289_0014_0001$$$::Οâ porque eu tava olhando pra saΟ≠da de emergΟΣncia?[lr]::
35382::$$$message_0289_0014_0002$$$::Eu sinto "algo" preto sendo atirado e eu-::
35383::$$$message_0289_0014_0003$$$::"Cuidado, Tohsaka!"[lr]::
35384::$$$message_0289_0014_0004$$$::...Eu protejo a Tohsaka com meu braΟßo direito.::
35385::$$$message_0289_0015_0000$$$::"Huh[line3]o-o que Ο© isso...!? Emiya-kun, s-seu braΟßo...!"[lr]::
35386::$$$message_0289_0015_0001$$$::"[line8]!"[lr]::
35387::$$$message_0289_0015_0002$$$::Assim como a Tohsaka disse, uma adaga preta tΟΓ perfurando meu braΟßo direito.::
35388::$$$message_0289_0016_0000$$$::A coisa se firmou entre meu pulso e meu braΟßo parece um prego.[lr]::
35389::$$$message_0289_0016_0001$$$::NΟΘo, Ο© muito grande pra chamar de prego.[lr]::
35390::$$$message_0289_0016_0002$$$::Algo como uma adaga perfurou meu braΟßo.::
35391::$$$message_0289_0017_0000$$$::"Por que[line3]nΟΘo, vocΟΣ tΟΓ sangrando muito. Isso nΟΘo dΟ≥i...?"[lr]::
35392::$$$message_0289_0017_0001$$$::"DΟ≥i. DΟ≥i muito."[lr]::
35393::$$$message_0289_0017_0002$$$::Mas dΟ≥i tanto que eu nΟΘo consigo entrar em pΟΔnico.[lr]::
35394::$$$message_0289_0017_0003$$$::Mas alΟ©m disso...[lr]::
35395::$$$message_0289_0017_0004$$$::AlguΟ©m jogou isso no rosto da Tohsaka?::
35396::$$$message_0289_0018_0000$$$::"[line4]Por favor cuida dela, Tohsaka."[lr]::
35397::$$$message_0289_0018_0001$$$::Eu comeΟßo a correr.[lr]::
35398::$$$message_0289_0018_0002$$$::Eu nΟΘo tenho tempo pra esperar pela resposta da Tohsaka.[lr]::
35399::$$$message_0289_0018_0003$$$::Eu aperto o cano de metal "fortalecido" na minha mΟΘo esquerda e corro pra fora da saΟ≠da de emergΟΣncia.::
35400::$$$message_0289_0019_0000$$$::"Fuh[line4]fuu, fuu, fu[line3]"[lr]::
35401::$$$message_0289_0019_0001$$$::Eu corro com meu braΟßo direito balanΟßando.[lr]::
35402::$$$message_0289_0019_0002$$$::O braΟßo tΟΓ vermelho abaixo do meu cotovelo.[lr]::
35403::$$$message_0289_0019_0003$$$::...Tem algum tipo de mΟΓ sorte com meus braΟßos hoje?[lr]::
35404::$$$message_0289_0019_0004$$$::A Tohsaka me disse pra dar pra ela meu selo de comando do meu braΟßo esquerdo e agora esse quase foi rasgado.::
35405::$$$message_0289_0020_0000$$$::"[line4]Tem que estar por aqui."[lr]::
35406::$$$message_0289_0020_0001$$$::Eu olho ao redor.[lr]::
35407::$$$message_0289_0020_0002$$$::Eu nΟΘo sei o que eu tΟ¥ sentindo, mas eu certamente sinto.[lr]::
35408::$$$message_0289_0020_0003$$$::A "pessoa" que atacou aquela estudante,[lr]::
35409::$$$message_0289_0020_0004$$$::a "pessoa" que atacou a Tohsaka com aquela adaga tΟΓ prΟ≥xima.[lr]::
35410::$$$message_0289_0020_0005$$$::A pessoa ainda tΟΓ por aqui.[lr]::
35411::$$$message_0289_0020_0006$$$::Se eu fechar meus olhos, eu consigo sentir energia mΟΓgica negra se movendo.::
35412::$$$message_0289_0021_0000$$$::"AtrΟΓs do estande de arco e flecha[line4]na floresta..!"[lr]::
35413::$$$message_0289_0021_0001$$$::Eu pulo a cerca e corro pela terra mofada.[lr]::
35414::$$$message_0289_0021_0002$$$::[line4]EntΟΘo.[lr]::
35415::$$$message_0289_0021_0003$$$::Entre as ΟΓrvores...[lr]::
35416::$$$message_0289_0021_0004$$$::AlguΟ©m que eu reconheΟßo tΟΓ parado lΟΓ, sorrindo.::
35417::$$$message_0289_0022_0000$$$::"Shinji...?"[lr]::
35418::$$$message_0289_0022_0001$$$::Eu paro.[lr]::
35419::$$$message_0289_0022_0002$$$::Por que o Shinji tΟΓ aqui?[lr]::
35420::$$$message_0289_0022_0003$$$::Ele tΟΓ desaparecido agora mesmo...[lr]::
35421::$$$message_0289_0022_0004$$$::NΟΘo, a Mitsuzuri Ο© quem tΟΓ desaparecida, o Shinji Ο© o ΟΚltimo que viu ela, e[line4]::
35422::$$$message_0289_0023_0000$$$::"[line4]!!!!!"[lr]::
35423::$$$message_0289_0023_0001$$$::O braΟßo ferido treme.[lr]::
35424::$$$message_0289_0023_0002$$$::No instante que eu caio no chΟΘo...[lr]::
35425::$$$message_0289_0023_0003$$$::Uma adaga como um prego Ο© impulsionada atΟ© minha garganta.::
35426::$$$message_0289_0024_0000$$$::"......!"[lr]::
35427::$$$message_0289_0024_0001$$$::Eu instantaneamente desvio.[lr]::
35428::$$$message_0289_0024_0002$$$::Eu sΟ≥ continuo caindo e continuo rolando pra frente pra evitar isso.::
35429::$$$message_0289_0025_0000$$$::"Ha[line4]guh......!!!!"[lr]::
35430::$$$message_0289_0025_0001$$$::Minha garganta.[lr]::
35431::$$$message_0289_0025_0002$$$::TΟΓ arranhada e a pele cortada.[lr]::
35432::$$$message_0289_0025_0003$$$::Mas isso Ο© meio fortuno.[lr]::
35433::$$$message_0289_0025_0004$$$::Se eu tivesse me atrasado por um segundo, teria sido minha garganta que seria cortada.::
35434::$$$message_0289_0026_0000$$$::"VocΟΣ...!"[lr]::
35435::$$$message_0289_0026_0001$$$::Eu instantaneamente me levanto.[lr]::
35436::$$$message_0289_0026_0002$$$::Na frente dela...[lr]::
35437::$$$message_0289_0026_0003$$$::...EstΟΓ uma mulher em preto com um sorriso irritante.::
35438::$$$message_0289_0027_0000$$$::"Um servo...!"[lr]::
35439::$$$message_0289_0027_0001$$$::Eu tenho certeza disso.[lr]::
35440::$$$message_0289_0027_0002$$$::Uma concentraΟßΟΘo de energia mΟΓgica que nem a Tohsaka aguentaria.[lr]::
35441::$$$message_0289_0027_0003$$$::Uma beleza etΟ©rea e o grosso cheiro de sangue.[lr]::
35442::$$$message_0289_0028_0000$$$::"Ela desapareceu...!?"[lr]::
35443::$$$message_0289_0028_0001$$$::A sombra escura desaparece da minha visΟΘo.[lr]::
35444::$$$message_0289_0028_0002$$$::[line4]Meus instintos me dizem que vou ser morto.[lr]::
35445::$$$message_0289_0028_0003$$$::Eu desesperadamente balanΟßo minha arma em cima de mim.::
35446::$$$message_0289_0029_0000$$$::"Guh[line4]!!"[lr]::
35447::$$$message_0289_0029_0001$$$::Eu paro o "prego" vindo atΟ© minha cabeΟßa.[lr]::
35448::$$$message_0289_0029_0002$$$::Ela Ο© como uma aranha, pulando pela floresta como se estivesse grudando nas ΟΓrvores.::
35449::$$$message_0289_0030_0000$$$::"[line8]"[lr]::
35450::$$$message_0289_0030_0001$$$::Eu corro.[lr]::
35451::$$$message_0289_0030_0002$$$::Foi sΟ≥ pura coincidΟΣncia que eu consegui bloquear aquele ataque surpresa.[lr]::
35452::$$$message_0289_0030_0003$$$::Eu nΟΘo consigo bloquear outro ataque, e nΟΘo tem como eu conseguir fugir.::
35453::$$$message_0289_0031_0000$$$::"Haa[line4]!"[lr]::
35454::$$$message_0289_0031_0001$$$::Eu corro atΟ© uma ΟΓrvore prΟ≥xima e encosto minhas costas nela.[lr]::
35455::$$$message_0289_0031_0002$$$::Eu devo ser capaz de bloquear quaisquer ataques que venham por trΟΓs de mim agora. NΟΘo, eu tenho que acreditar que eu consigo.::
35456::$$$message_0289_0032_0000$$$::"Droga[line4]a figura dela chama muita atenΟßΟΘo, entΟΘo[line4]"[lr]::
35457::$$$message_0289_0032_0001$$$::Eu nΟΘo vejo o Servo em preto em nenhum lugar.[lr]::
35458::$$$message_0289_0032_0002$$$::Ela pode estar pulando de galho em galho, jΟΓ que eu nΟΘo vejo ela descendo.::
35459::$$$message_0289_0033_0000$$$::"[line8]"[lr]::
35460::$$$message_0289_0033_0001$$$::Suor rola pela minha testa.[lr]::
35461::$$$message_0289_0033_0002$$$::O som das correntes Ο© como o de uma cobra mirando sua presa.::
35462::$$$message_0289_0034_0000$$$::"Ha[line4]Haha, ha."[lr]::
35463::$$$message_0289_0034_0001$$$::Eu suprimo a risada tentando me escapar.[lr]::
35464::$$$message_0289_0034_0002$$$::O som das correntes ecoa pela floresta.[lr]::
35465::$$$message_0289_0034_0003$$$::Mesmo que eu possa ser morto no prΟ≥ximo momento, minha mente tΟΓ completamente vazia.[lr]::
35466::$$$message_0289_0034_0004$$$::Eu nΟΘo tenho nenhuma noΟßΟΘo de tempo, e a guilhotina nΟΘo tΟΓ descendo.::
35467::$$$message_0289_0035_0000$$$::"Ha[line4]Ha, ha."[lr]::
35468::$$$message_0289_0035_0001$$$::Οâ isso que Ο© estranho.[lr]::
35469::$$$message_0289_0035_0002$$$::A batalha jΟΓ deveria ter acabado.::
35470::$$$message_0289_0036_0000$$$::Mas eu ainda tΟ¥ vivo.[lr]::
35471::$$$message_0289_0036_0001$$$::Οâ tΟΘo estranho que eu penso que eu talvez tenha sido morto pelo ΟΚltimo ataque e tΟ¥ meramente sonhando agora.::
35472::$$$message_0289_0037_0000$$$::"[line4]Saber."[lr]::
35473::$$$message_0289_0037_0001$$$::...Eu nΟΘo sou pΟΓreo pra um servo.[lr]::
35474::$$$message_0289_0037_0002$$$::EntΟΘo eu tenho que depender dela.[lr]::
35475::$$$message_0289_0037_0003$$$::O selo de comando. Se eu usar o selo de comando pra chamar a Saber, eu devo ser capaz de escapar dessa situaΟßΟΘo.::
35476::$$$message_0289_0038_0000$$$::Mas[line4]tudo bem isso?[lr]::
35477::$$$message_0289_0038_0001$$$::Eu me coloquei nessa situaΟßΟΘo perigosa. EntΟΘo, eu deveria ser responsΟΓvel por isso, e acima de tudo[line4]::
35478::$$$message_0289_0039_0000$$$::"[line4]Eu nΟΘo fiz tudo que eu consigo fazer."[lr]::
35479::$$$message_0289_0039_0001$$$::Isso mesmo.[lr]::
35480::$$$message_0289_0039_0002$$$::Eu tenho uma arma nas minhas mΟΘos, mesmo que seja uma fraca.[lr]::
35481::$$$message_0289_0039_0003$$$::E meu corpo ainda consegue se mover.[lr]::
35482::$$$message_0289_0039_0004$$$::Se essa Ο© uma posiΟßΟΘo ruim, eu sΟ≥ tenho que me mover.[lr]::
35483::$$$message_0289_0039_0005$$$::Eu posso chamar a Saber depois disso[line4]::
35484::$$$message_0289_0040_0000$$$::"Eu estou surpresa. VocΟΣ nΟΘo estΟΓ usando seu selo de comando?"[lr]::
35485::$$$message_0289_0040_0001$$$::"[line4]!"[lr]::
35486::$$$message_0289_0040_0002$$$::A voz ecoa.[lr]::
35487::$$$message_0289_0040_0003$$$::Ela tΟΓ em cima de mim[line4]em um galho em algum lugar, como esperado.::
35488::$$$message_0289_0041_0000$$$::"...Heh. Infelizmente, eu nΟΘo tenho muitos sobrando, entΟΘo eu nΟΘo sei o que eu vou fazer no futuro se eu usar algo assim."[lr]::
35489::$$$message_0289_0041_0001$$$::E bom, eu meio que nΟΘo sei como usar ele.::
35490::$$$message_0289_0042_0000$$$::"...Entendo. VocΟΣ deve ser corajoso ao contrΟΓrio do meu mestre."[lr]::
35491::$$$message_0289_0042_0001$$$::Eu procuro ao meu redor.[lr]::
35492::$$$message_0289_0042_0002$$$::De onde que tΟΓ vindo essa voz[line4]?::
35493::$$$message_0289_0043_0000$$$::"EntΟΘo eu irei alterar meu curso de aΟßΟΘo. Eu nΟΘo posso dar meu mΟΓximo contra um mestre sem seu servo[line3]Eu irei gentilmente lhe matar."[lr]::
35494::$$$message_0289_0043_0001$$$::...A voz para.[lr]::
35495::$$$message_0289_0043_0002$$$::O som das correntes Ο© o ΟΚnico som ecoando pela floresta.::
35496::$$$message_0289_0044_0000$$$::"[line8]"[lr]::
35497::$$$message_0289_0044_0001$$$::Ela tΟΓ vindo.[lr]::
35498::$$$message_0289_0044_0002$$$::O que eu tenho que fazer Ο© sair desse lugar.[lr]::
35499::$$$message_0289_0044_0003$$$::Pra fazer isso, eu teria que bloquear o "prego" dela algumas vezes.::
35500::$$$message_0289_0045_0000$$$::"......"[lr]::
35501::$$$message_0289_0045_0001$$$::O fato de que eu tenho que me defender usando a perna de uma cadeira Ο© tΟΘo patΟ©tico que Ο© engraΟßado.[lr]::
35502::$$$message_0289_0045_0002$$$::Se eu pelo menos tivesse[line4][lr]::
35503::$$$message_0289_0045_0003$$$::Se essa vareta fosse tΟΘo esplΟΣndida quanto as armas que ele tem, eu talvez conseguiria atΟ© contra-atacar.::
35504::$$$message_0289_0046_0000$$$::"[line22][r]::
35505::$$$message_0289_0046_0001$$$::[line22][r]::
35506::$$$message_0289_0046_0002$$$::[line13]Aqui vou eu."[lr]::
35507::$$$message_0289_0046_0003$$$::...Eu nΟΘo tenho tempo pra pensar em e se.[lr]::
35508::$$$message_0289_0046_0004$$$::Tem por volta de 30 metros atΟ© a saΟ≠da da floresta.[lr]::
35509::$$$message_0289_0046_0005$$$::Isso nΟΘo Ο© muito comparado a perseguiΟßΟΘo que eu tive com a [r]Tohsaka[line4]!::
35510::$$$message_0289_0047_0000$$$::[line4]Eu corro.[lr]::
35511::$$$message_0289_0047_0001$$$::Eu ignoro o som irritante das corrente e corro freneticamente atΟ© a saΟ≠da...!::
35512::$$$message_0289_0048_0000$$$::"Fuh[line4]!"[lr]::
35513::$$$message_0289_0048_0001$$$::Eu repeli o ataque de cima.[lr]::
35514::$$$message_0289_0048_0002$$$::E entΟΘo, usando a arma, eu bloqueio o chute circular executado pelo servo.[lr]::
35515::$$$message_0289_0048_0003$$$::Ela tΟΓ na minha frente agora.[lr]::
35516::$$$message_0289_0048_0004$$$::Eu repeli os ataques dela[line4]!::
35517::$$$message_0289_0049_0000$$$::"Sem chance[line4]!?"[lr]::
35518::$$$message_0289_0049_0001$$$::O servo de preto recua.::
35519::$$$message_0289_0050_0000$$$::"[line8]"[lr]::
35520::$$$message_0289_0050_0001$$$::Οâ sΟ≥ uma coincidΟΣncia.[lr]::
35521::$$$message_0289_0050_0002$$$::Se o primeiro ataque foi bloqueado por coincidΟΣncia, esses ataques tambΟ©m foram bloqueados por chance.[lr]::
35522::$$$message_0289_0050_0003$$$::Eu nΟΘo consigo nem ver os movimentos dela.[lr]::
35523::$$$message_0289_0050_0004$$$::Eu ficar vivo mesmo assim nΟΘo Ο© nada alΟ©m de pura sorte.::
35524::$$$message_0289_0051_0000$$$::[line4]Mas.[lr]::
35525::$$$message_0289_0051_0001$$$::CoincidΟΣncias sΟΘo algo que continuam dessa forma?[lr]::
35526::$$$message_0289_0051_0002$$$::NΟΘo, e se minhas premissas tiverem erradas?[lr]::
35527::$$$message_0289_0051_0003$$$::O primeiro ataque.[lr]::
35528::$$$message_0289_0051_0004$$$::O ataque surpresa na minha cabeΟßa.[lr]::
35529::$$$message_0289_0051_0005$$$::Emiya Shirou nΟΘo conseguiria bloquear ataques assim.[lr]::
35530::$$$message_0289_0051_0006$$$::Eu nΟΘo consigo bloquear eles por coincidΟΣncia[line4]::
35531::$$$message_0289_0052_0000$$$::"[line4]VocΟΣ..."[lr]::
