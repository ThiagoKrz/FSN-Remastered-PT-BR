DAT
id=qid::label=str::text=lstr::
73631::$$$message_0677_0000_0000$$$::"Zouken......!!!!"[lr]::
73632::$$$message_0677_0000_0001$$$::Eu vou lidar com isso agora.[lr]::
73633::$$$message_0677_0000_0002$$$::Zouken deve estar em algum lugar dessa casa. Eu vou encontrar ele e o matar...!::
73634::$$$message_0677_0001_0000$$$::"Merda, cadê você, velho desgraçado...!?"[lr]::
73635::$$$message_0677_0001_0001$$$::Eu não consigo encontrar ele em nenhum lugar da casa.[lr]::
73636::$$$message_0677_0001_0002$$$::A presença dele se esvai a cada segundo.[lr]::
73637::$$$message_0677_0001_0003$$$::'Ah, minha nossa. Você deve estar cegado pela sua raiva.[r]::
73638::$$$message_0677_0001_0004$$$::Eu pensei que você seria mais esperto.'[lr]::
73639::$$$message_0677_0001_0005$$$::Até sua risada está desaparecendo.::
73640::$$$message_0677_0002_0000$$$::"Haa[w l=4][line4]Haa, haa, ha[w l=4][line4]"[lr]::
73641::$$$message_0677_0002_0001$$$::...Zouken não está aqui.[lr]::
73642::$$$message_0677_0002_0002$$$::Ele nunca esteve nessa casa em primeiro lugar.[lr]::
73643::$$$message_0677_0002_0003$$$::Ele é um usuário de minhocas. Os únicos aqui são as minhocas...!::
73644::$$$message_0677_0003_0000$$$::"Você está satisfeito agora? Então volte para casa, Emiya Shirou.[lr]::
73645::$$$message_0677_0003_0001$$$::Sakura irá logo engolir Illyasviel. Se você não se apressar, você não estará lá para o nascimento do monstro que você criou."[lr]::
73646::$$$message_0677_0003_0002$$$::"Velho desgraçado...!"::
73647::$$$message_0677_0004_0000$$$::Eu chuto o chão forte o suficiente para rasgar minhas pernas fora.[lr]::
73648::$$$message_0677_0004_0001$$$::Ser pego pela minha raiva gastou muito tempo.[lr]::
73649::$$$message_0677_0004_0002$$$::Vai demorar mais vinte minutos para eu chegar em casa, mesmo correndo em velocidade máxima.[lr]::
73650::$$$message_0677_0004_0003$$$::[w l=3][line3]Eu vou chegar a tempo?[lr]::
73651::$$$message_0677_0004_0004$$$::Eu tenho que voltar pra casa antes que a Sakura encontre a Illya[w l=3][line3]!::
