DAT
id=qid::label=str::text=lstr::
73383::$$$message_0673_0000_0000$$$::"[w l=8][line8]Que?"[lr]::
73384::$$$message_0673_0000_0001$$$::A primeira coisa que eu sinto quando entro em casa Ă© um calafrio.[lr]::
73385::$$$message_0673_0000_0002$$$::NĂŁo hĂĄ nada errado, e nĂŁo hĂĄ sinal de perigo.[lr]::
73386::$$$message_0673_0000_0003$$$::Mas eu tenho um mal pressentimento.::
73387::$$$message_0673_0001_0000$$$::NĂŁo tem ninguĂ©m na sala de estar.[lr]::
73388::$$$message_0673_0001_0001$$$::Illya estĂĄ dormindo no quarto dela.[lr]::
73389::$$$message_0673_0001_0002$$$::Tohsaka estĂĄ se preparando para a projeĂ§ĂŁo no quarto dela.[lr]::
73390::$$$message_0673_0001_0003$$$::A Sakura estĂĄ...[w l=4][line4]::
73391::$$$message_0673_0002_0000$$$::"Estou entrando, Sakura."[lr]::
73392::$$$message_0673_0002_0001$$$::Eu aviso e coloco a mĂŁo na maĂ§aneta.[lr]::
73393::$$$message_0673_0002_0002$$$::[w l=3][line3]Sinto uma sensaĂ§ĂŁo fria nas costas.[lr]::
73394::$$$message_0673_0002_0003$$$::Eu tento me livrar do desconforto e abro a porta.::
73395::$$$message_0673_0003_0000$$$::"Sakura."[lr]::
73396::$$$message_0673_0003_0001$$$::"......!"[lr]::
73397::$$$message_0673_0003_0002$$$::Eu vejo a Rider por um segundo, mas a sua figura desaparece.[lr]::
73398::$$$message_0673_0003_0003$$$::AtrĂĄs dela...[lr]::
73399::$$$message_0673_0003_0004$$$::A cama em que a Sakura deveria estar dormindo estĂĄ vazia.::
73400::$$$message_0673_0004_0000$$$::"[w l=4][line4]!"[lr]::
73401::$$$message_0673_0004_0001$$$::A luz se acende.[lr]::
73402::$$$message_0673_0004_0002$$$::"QuĂȘ[w l=4][line4]"[lr]::
73403::$$$message_0673_0004_0003$$$::Eu olho ao redor surpreso.[lr]::
73404::$$$message_0673_0004_0004$$$::"Bem-vindo de volta. NĂŁo vou perguntar onde vocĂȘ esteve, mas vocĂȘ demorou mais do que deveria."::
73405::$$$message_0673_0005_0000$$$::"Tohsaka...? O que Ă© isso[w l=4][line4]?"[lr]::
73406::$$$message_0673_0005_0001$$$::"NĂŁo Ă© Ăłbvio? Sakura saiu sozinha, e a Rider ficou me encarando esse tempo todo.[lr]::
73407::$$$message_0673_0005_0002$$$::...Acho que ela estĂĄ sobre ordens de nĂŁo te machucar. Ela mudou para a forma de espĂ­rito e fugiu assim que vocĂȘ entrou no quarto."::
73408::$$$message_0673_0006_0000$$$::"QuĂȘ[w l=4][line4]"[lr]::
73409::$$$message_0673_0006_0001$$$::Tohsaka parece calma.[lr]::
73410::$$$message_0673_0006_0002$$$::...NĂŁo, nĂŁo Ă© isso.[lr]::
73411::$$$message_0673_0006_0003$$$::Sua voz nĂŁo parece calma.[lr]::
73412::$$$message_0673_0006_0004$$$::Seu tom de voz Ă© de desinteresse, como se ela tivesse desistido de algo.::
73413::$$$message_0673_0007_0000$$$::"[w l=4][line4]Tohsaka. A Sakura saiu mesmo de casa...?""[lr]::
73414::$$$message_0673_0007_0001$$$::"Ă verdade. Ela saiu antes de vocĂȘ ter saĂ­do, entĂŁo jĂĄ fazen mais de duas horas.[lr]::
73415::$$$message_0673_0007_0002$$$::Ela fez a Rider me impedir de ir atrĂĄs dela, entĂŁo ela nĂŁo deve estar querendo que a gente saiba o que ela estĂĄ fazendo."::
73416::$$$message_0673_0008_0000$$$::"NĂŁo seja idiota...! Sakura nunca esconderia... nada... [r]da gente[w l=4][line4]"[lr]::
73417::$$$message_0673_0008_0001$$$::Eu nĂŁo posso dizer com certeza.[lr]::
73418::$$$message_0673_0008_0002$$$::...O pesadelo da Sakura.[lr]::
73419::$$$message_0673_0008_0003$$$::Eu nĂŁo faĂ§o idĂ©ia do que a Sakura pensa sobre o seu corpo se deteriorando.::
73420::$$$message_0673_0009_0000$$$::"Temos que trazer ela de volta...! Se a deixarmos sozinha..."[lr]::
73421::$$$message_0673_0009_0001$$$::"HaverĂĄ mais vĂ­timas. Ela pode acabar sugando a energia mĂĄgica de qualquer um que ela ver pela frente, assim como ela me atacou na escola.[lr]::
73422::$$$message_0673_0009_0002$$$::NinguĂ©m foi atacado pela sombra na noite passada, nĂŁo Ă©? Por isso ela deve estar com fome."::
73423::$$$message_0673_0010_0000$$$::"[line12]Tohsaka."[lr]::
73424::$$$message_0673_0010_0001$$$::Tohsaka desvia o olhar e engole suas palavras.[lr]::
73425::$$$message_0673_0010_0002$$$::Seus olhos me dizem para eu desistir,[lr]::
73426::$$$message_0673_0010_0003$$$::me dizendo que acabou.::
73427::$$$message_0673_0011_0000$$$::"Tohsaka, vocĂȘ..."[lr]::
73428::$$$message_0673_0011_0001$$$::"Podemos procurar pela Sakura. Nisso eu concordo.[lr]::
73429::$$$message_0673_0011_0002$$$::Mas[w l=3][line3]assim que a encontrarmos... VocĂȘ sabe o que fazer se a Sakura nĂŁo for mais ela mesma, nĂ©?"::
73430::$$$message_0673_0012_0000$$$::"[w l=3][line3]Isso nĂŁo Ă© possĂ­vel. Sakura sempre serĂĄ a Sakura."[lr]::
73431::$$$message_0673_0012_0001$$$::"VocĂȘ tĂĄ maluco? NĂŁo consegue ver que ela jĂĄ estĂĄ no limite? Desiste, Shirou. Se continuar protegendo ela, vocĂȘ serĂĄ o primeiro a morrer[w l=4][line4]"::
73432::$$$message_0673_0013_0000$$$::"Podemos fazer especulaĂ§Ă”es idiotas depois. Temos que encontrar a Sakura e trazer ela de volta o mais rĂĄpido possĂ­vel. Depois disso podemos discutir o quanto vocĂȘ quiser, entĂŁo fique calada por enquanto...!"[lr]::
73433::$$$message_0673_0013_0001$$$::"Ei, espera, Shirou[w l=4][line4]!"::
73434::$$$message_0673_0014_0000$$$::Eu corro pelo corredor.[lr]::
73435::$$$message_0673_0014_0001$$$::NĂŁo tenho tempo pra pensar sobre onde a Sakura foi.[lr]::
73436::$$$message_0673_0014_0002$$$::'[w l=4][line4]JĂĄ acabou, Shirou.'[lr]::
73437::$$$message_0673_0014_0003$$$::Eu corro pra fora a toda velocidade, como se estivesse negando as suas palavras.::
73438::$$$message_0673_0015_0000$$$::"Shirou. VocĂȘ vai procurar pela Sakura?"[lr]::
73439::$$$message_0673_0015_0001$$$::"[w l=4][line4]"[lr]::
73440::$$$message_0673_0015_0002$$$::E entĂŁo.[lr]::
73441::$$$message_0673_0015_0003$$$::AlguĂ©m que eu nĂŁo esperava me chama por trĂĄs.::
73442::$$$message_0673_0016_0000$$$::...Quando foi que ela chegou aqui?[lr]::
73443::$$$message_0673_0016_0001$$$::Illya estĂĄ me olhando de longe, como se houvesse uma parede entre nĂłs.::
73444::$$$message_0673_0017_0000$$$::"...Illya."[lr]::
73445::$$$message_0673_0017_0001$$$::"Diga-me, Shirou. VocĂȘ vai procurar pela Sakura?"[lr]::
73446::$$$message_0673_0017_0002$$$::"[w l=8][line8]"[lr]::
73447::$$$message_0673_0017_0003$$$::Eu aceno que sim.[lr]::
73448::$$$message_0673_0017_0004$$$::A voz da Illya estĂĄ tensa.[lr]::
73449::$$$message_0673_0017_0005$$$::O desespero na sua voz Ă© diferente da Tohsaka. Por ser um Santo Graal, Illya deve saber em que condiĂ§ĂŁo a Sakura estĂĄ.::
73450::$$$message_0673_0018_0000$$$::"Entendo. Mas Shirou, Sakura saiu sozinha porque ela nĂŁo queria que vocĂȘ a visse. Ela estĂĄ com medo e nĂŁo quer morrer, mas ainda assim escolheu resolver tudo sozinha para te proteger.[lr]::
73451::$$$message_0673_0018_0001$$$::A Sakura que vocĂȘ ama nĂŁo existe mais. Ela saiu sozinha para eliminar a si mesma."::
73452::$$$message_0673_0019_0000$$$::"[w l=8][line8]"[lr]::
73453::$$$message_0673_0019_0001$$$::Illya olha direto nos meus olhos.[lr]::
73454::$$$message_0673_0019_0002$$$::Nossos olhos se encontram, e eu balanĂ§o a cabeĂ§a.[lr]::
73455::$$$message_0673_0019_0003$$$::Eu nĂŁo vou deixar isso acontecer.[lr]::
73456::$$$message_0673_0019_0004$$$::Mesmo se a Sakura nĂŁo for mais a Sakura que conheĂ§o, sĂł hĂĄ uma coisa que eu possa fazer.::
73457::$$$message_0673_0020_0000$$$::"......Entendo. Mas Shirou. Eu e a Sakura temos uma outra 'eu' dentro de nĂłs. Provavelmente nĂŁo Ă© a Illya que vocĂȘ conhece, e nĂŁo Ă© a Sakura que vocĂȘ conhece.[lr]::
73458::$$$message_0673_0020_0001$$$::Sakura nĂŁo vai voltar mais. Ela serĂĄ uma pessoa diferente assim que ela mudar.[lr]::
73459::$$$message_0673_0020_0002$$$::Mas vocĂȘ ainda se recusa a matar ela, Shirou?"::
73460::$$$message_0673_0021_0000$$$::Uma pergunta quieta.[lr]::
73461::$$$message_0673_0021_0001$$$::Isso Ă© o que a Illya queria dizer.[lr]::
73462::$$$message_0673_0021_0002$$$::O Santo Graal Ă© feito com a premissa de se quebrar.[lr]::
73463::$$$message_0673_0021_0003$$$::Por isso eu nĂŁo preciso hesitar em destruĂ­-la.[lr]::
73464::$$$message_0673_0021_0004$$$::Mas pra mim, parece que ela estĂĄ falando dela mesma ao invĂ©s da Sakura.::
73465::$$$message_0673_0022_0000$$$::"Shirou. Deixe-me lhe perguntar mais uma vez.[lr]::
73466::$$$message_0673_0022_0001$$$::VocĂȘ ainda pretende procurar pela Sakura?"[lr]::
73467::$$$message_0673_0022_0002$$$::"........."[lr]::
73468::$$$message_0673_0022_0003$$$::Eu nĂŁo sei quanta emoĂ§ĂŁo essa pergunta carrega.[lr]::
73469::$$$message_0673_0022_0004$$$::Por isso eu falo honestamente sobre o caminho que eu escolhi.::
73470::$$$message_0673_0023_0000$$$::"Sim, estou indo procurar por ela. Pra mim, Sakura sempre serĂĄ a Sakura. O mesmo vale pra vocĂȘ. Mesmo se vocĂȘ virar algo misterioso como um Santo Graal, vocĂȘ ainda serĂĄ a Illya."::
73471::$$$message_0673_0024_0000$$$::"...NĂŁo importa o quanto vocĂȘ mude.[lr]::
73472::$$$message_0673_0024_0001$$$::Se a Illya estiver dentro de vocĂȘ, vocĂȘ serĂĄ a Illya que eu conheĂ§o."::
73473::$$$message_0673_0025_0000$$$::"[w l=4][line4]"[lr]::
73474::$$$message_0673_0025_0001$$$::"Eu nĂŁo sei sobre coisas complicadas. Isso Ă© tudo com o que me importo."::
73475::$$$message_0673_0026_0000$$$::Eu coloco a minha mĂŁo na porta.[lr]::
73476::$$$message_0673_0026_0001$$$::"...A casa do Zouken. Esse Ă© o Ășnico lugar que a Sakura pode ter ido."[lr]::
73477::$$$message_0673_0026_0002$$$::Eu a ouĂ§o atrĂĄs de mim.[lr]::
73478::$$$message_0673_0026_0003$$$::"Tudo bem. Por favor espere aqui, Illya. Vou encontrar a Sakura e trazer ela de volta agora mesmo."::
73479::$$$message_0673_0027_0000$$$::Eu saio.[lr]::
73480::$$$message_0673_0027_0001$$$::Illya permanece em pĂ© no corredor, como se estivesse vendo algo muito distante.::
73481::$$$message_0673_0028_0000$$$::Eu chego na residĂȘncia dos Matous.[lr]::
73482::$$$message_0673_0028_0001$$$::Eu nĂŁo estou sem fĂŽlego.[lr]::
73483::$$$message_0673_0028_0002$$$::Meu corpo deve estar cansado depois de correr tanto, mas ele nĂŁo reclama nenhum pouco.::
73484::$$$message_0673_0029_0000$$$::"...EstĂĄ aberta."[lr]::
73485::$$$message_0673_0029_0001$$$::Eu paro antes de apertar a campainha.[lr]::
73486::$$$message_0673_0029_0002$$$::...SerĂĄ que alguĂ©m entrou ou saiu?[lr]::
73487::$$$message_0673_0029_0003$$$::A porta da frente estĂĄ entreaberta, e estĂĄ um completo silĂȘncio lĂĄ dentro.::
73488::$$$message_0673_0030_0000$$$::Eu nĂŁo sinto nenhuma presenĂ§a humana.[lr]::
73489::$$$message_0673_0030_0001$$$::A residĂȘncia dos Matous estĂĄ mais sombria do que ontem.::
73490::$$$message_0673_0031_0000$$$::NĂŁo hĂĄ ninguĂ©m no primeiro andar.[lr]::
73491::$$$message_0673_0031_0001$$$::Meus passos ecoam pelo corredor.[lr]::
73492::$$$message_0673_0031_0002$$$::O chĂŁo range enquanto caminho atĂ© as escadas.::
73493::$$$message_0673_0032_0000$$$::NĂŁo tem ninguĂ©m no segundo andar.[lr]::
73494::$$$message_0673_0032_0001$$$::Eu vejo o cĂ©u pela janela no topo da escada.[lr]::
73495::$$$message_0673_0032_0002$$$::Assim que chego no topo da escada, consigo sentir que nĂŁo tem ninguĂ©m no segundo andar.::
73496::$$$message_0673_0033_0000$$$::Eu me viro para descer as escadas, mas eu paro.[lr]::
73497::$$$message_0673_0033_0001$$$::Uma pessoa viva.[lr]::
73498::$$$message_0673_0033_0002$$$::A sensaĂ§ĂŁo estranha me faz caminhar atĂ© o quarto com a porta entreaberta.::
73499::$$$message_0673_0034_0000$$$::[w l=4][line4]Ă o quarto da Sakura..[lr]::
73500::$$$message_0673_0034_0001$$$::Eu jĂĄ o vi antes.[lr]::
73501::$$$message_0673_0034_0002$$$::Mas eu nunca cheguei a entrar no quarto.[lr]::
73502::$$$message_0673_0034_0003$$$::Ă porque a Sakura nos expulsou com o rosto vermelho quando o Shinji me trouxe aqui.::
73503::$$$message_0673_0035_0000$$$::Acho que isso foi hĂĄ dois anos atrĂĄs.[lr]::
73504::$$$message_0673_0035_0001$$$::Nada mudou.[lr]::
73505::$$$message_0673_0035_0002$$$::O quarto de uma garota. Ă um quarto simples que combina com a Sakura.[lr]::
73506::$$$message_0673_0035_0003$$$::E na cama...[lr]::
73507::$$$message_0673_0035_0004$$$::"[w l=4][line4]Shinji."[lr]::
73508::$$$message_0673_0035_0005$$$::...EstĂĄ o cadĂĄver de Matou Shinji.ŒËæ&