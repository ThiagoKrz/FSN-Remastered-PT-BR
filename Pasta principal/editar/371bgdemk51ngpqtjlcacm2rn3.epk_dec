DAT
id=qid::label=str::text=lstr::
62081::$$$message_0571_0000_0000$$$::"Pare, Nii-san...![lr]::
62082::$$$message_0571_0000_0001$$$::Por favor, nĂŁo aqui[w l=3][line3]!"[lr]::
62083::$$$message_0571_0000_0002$$$::Eu me recomponho ao ouvir sua voz.::
62084::$$$message_0571_0001_0000$$$::"[w l=4][line4]Sakura."[lr]::
62085::$$$message_0571_0001_0001$$$::"Que surpresa. NĂŁo seria essa a primeira vez que vocĂȘ fala comigo assim?"[lr]::
62086::$$$message_0571_0001_0002$$$::A voz do Shinji soa tĂŁo alegre como nunca ouvi antes.[lr]::
62087::$$$message_0571_0001_0003$$$::A Sakura estĂĄ abaixando a cabeĂ§a, seu corpo tremendo.::
62088::$$$message_0571_0002_0000$$$::"EntĂŁo? Fala de novo. NĂŁo te ouvi direito."[lr]::
62089::$$$message_0571_0002_0001$$$::"EntĂŁo, o que vocĂȘ quer, Sakura? Ficar aqui, ou voltar? Sou bonzinho, entĂŁo ouvirei a opiniĂŁo da minha querida irmĂŁzinha."[lr]::
62090::$$$message_0571_0003_0000$$$::"Ahh. EntĂŁo vai fazer o que eu quiser?"[lr]::
62091::$$$message_0571_0003_0001$$$::"EntĂŁo vai fazer o que eu disser?"[lr]::
62092::$$$message_0571_0003_0002$$$::"........."[lr]::
62093::$$$message_0571_0004_0000$$$::"Entendo. Se estĂĄ tĂŁo determinada, nĂŁo vou te levar. Afinal, um irmĂŁozĂŁo tem que respeitar os desejos de sua irmĂŁ. NĂŁo Ă©, Emiya?"[lr]::
62094::$$$message_0571_0004_0001$$$::"Entendo. Se estĂĄ tĂŁo determinada, nĂŁo vou te levar. Sou um irmĂŁozĂŁo leniente, entĂŁo tenho que respeitar os desejos de minha irmĂŁ. NĂŁo Ă©, Emiya?"[lr]::
62095::$$$message_0571_0005_0000$$$::"Haha. NĂŁo faĂ§a uma cara tĂŁo assustadora. Foi sĂł uma piada. As pessoas vĂŁo pensar coisas erradas de vocĂȘ se nĂŁo esquecer as magoas."[lr]::
62096::$$$message_0571_0005_0001$$$::Shinji caminha em direĂ§ĂŁo a porta.::
62097::$$$message_0571_0006_0000$$$::"Tchau. Cuide dela, Emiya.[lr]::
62098::$$$message_0571_0006_0001$$$::[w l=3][line3]Mas nĂŁo esqueĂ§a o que vocĂȘ acabou de dizer, Sakura."[lr]::
62099::$$$message_0571_0006_0002$$$::[w l=3][line3]Mas volte quando quiser, Sakura."[lr]::
62100::$$$message_0571_0006_0003$$$::Shinji dĂĄ tchau e vai embora.[lr]::
62101::$$$message_0571_0007_0000$$$::Voltamos a cozinhar.[lr]::
62102::$$$message_0571_0007_0001$$$::"........."[lr]::
62103::$$$message_0571_0007_0002$$$::Sem saber o que dizer, corto os tomates e abobĂłras em silĂȘncio.[lr]::
62104::$$$message_0571_0007_0003$$$::O som ininterrupto de cortar dĂĄ Ă  cozinha uma atmosfera incomodante.::
62105::$$$message_0571_0008_0000$$$::"O arroz estĂĄ pronto, Senpai. A Fujimura-Sensei nĂŁo chegou ainda, mas podemos comer sem ela, nĂ©?"[lr]::
62106::$$$message_0571_0008_0001$$$::"Ah[w l=3][line3]sim. EstĂĄ um pouco cedo, mas vamos fazer isso."[lr]::
62107::$$$message_0571_0008_0002$$$::"Okay. Vou preparar tudo."::
62108::$$$message_0571_0009_0000$$$::Sakura se move rapidamente, como se nada tivesse acontecido.::
62109::$$$message_0571_0010_0000$$$::...ela estĂĄ obviamente se forĂ§ando.[lr]::
62110::$$$message_0571_0010_0001$$$::Ela finge estĂĄ bem para que eu nĂŁo me preocupe.::
62111::$$$message_0571_0011_0000$$$::"......"[lr]::
62112::$$$message_0571_0011_0001$$$::Devo agir igual se ela for agir assim.[lr]::
62113::$$$message_0571_0011_0002$$$::Foi a Sakura quem se machucou.[lr]::
62114::$$$message_0571_0011_0003$$$::Ă a Sakura quem estĂĄ incomodada.[lr]::
62115::$$$message_0571_0012_0000$$$::"Sakura?"[lr]::
62116::$$$message_0571_0012_0001$$$::O som da tigela quebrando me faz virar.[lr]::
62117::$$$message_0571_0012_0002$$$::"[w l=8][line8]"[lr]::
62118::$$$message_0571_0012_0003$$$::PedaĂ§os da tigela quebrada estĂŁo ao redor dos pĂ©s dela.::
62119::$$$message_0571_0013_0000$$$::"[w l=8][line8]"[lr]::
62120::$$$message_0571_0013_0001$$$::".....!"[lr]::
62121::$$$message_0571_0013_0002$$$::A Sakura desmaia de repente.[lr]::
62122::$$$message_0571_0013_0003$$$::Ela se escorrega atĂ© sentar, e entĂŁo vira de costas[w l=4][line4]::
62123::$$$message_0571_0014_0000$$$::"Sakura[w l=3][line3]!"[lr]::
62124::$$$message_0571_0014_0001$$$::Rapidamente pego ela do chĂŁo.[lr]::
62125::$$$message_0571_0014_0002$$$::"Ow...!?"[lr]::
62126::$$$message_0571_0014_0003$$$::O corpo dela estĂĄ fervendo, atĂ© mesmo pelo uniforme.::
62127::$$$message_0571_0014_0004$$$::I can feel Sakura's fever even through her uniform.::
62128::$$$message_0571_0015_0000$$$::"Sakura... ei, Sakura...!"[lr]::
62129::$$$message_0571_0015_0001$$$::"Eh[w l=4][line4]Sen... pai...? O que... estĂĄ acontecendo...?"::
62130::$$$message_0571_0016_0000$$$::NĂŁo hĂĄ forĂ§a em sua voz.[lr]::
62131::$$$message_0571_0016_0001$$$::Mas ela tenta ao mĂĄximo dizer algo.::
62132::$$$message_0571_0017_0000$$$::"Nada de 'o que estĂĄ acontecendo'...!? VocĂȘ ainda estĂĄ doente...!"[lr]::
62133::$$$message_0571_0017_0001$$$::"Ah... nĂŁo... estou bem."[lr]::
62134::$$$message_0571_0017_0002$$$::"Sua idiota...! VocĂȘ nĂŁo desmaiaria assim se estivesse bem!"::
62135::$$$message_0571_0018_0000$$$::[w l=3][line3]Droga, eu sou um idiota.[lr]::
62136::$$$message_0571_0018_0001$$$::Eu sabia que ela estava resfriada, mas abusei dela sem pensar.[lr]::
62137::$$$message_0571_0018_0002$$$::E para terminar, hĂĄ o que aconteceu agora. Depois de tudo que ela passou fisicamente e emocionalmente, Ă© Ăłbvio que ela desmaiaria[w l=4][line4]!::
62138::$$$message_0571_0019_0000$$$::"Me desculpa por ter quebrado a tigela, Senpai.[lr]::
62139::$$$message_0571_0019_0001$$$::Vou limpar tudo imed[w l=3][line3]kya!?"[lr]::
62140::$$$message_0571_0019_0002$$$::Levanto ela com meus braĂ§os.::
62141::$$$message_0571_0020_0000$$$::"S-Senpai!?"[lr]::
62142::$$$message_0571_0020_0001$$$::"O jantar pode esperar. Vou te levar para a calma e fazer vocĂȘ descansar. Reclame comigo depois que melhorar."::
62143::$$$message_0571_0021_0000$$$::Eu vou atĂ© o quarto anexo com ela em meus braĂ§os.[lr]::
62144::$$$message_0571_0021_0001$$$::Ela estĂĄ tentando dizer algo, mas ignoro-a.[lr]::
62145::$$$message_0571_0021_0002$$$::Estou tĂŁo bravo que nem consigo conversar.::
62146::$$$message_0571_0022_0000$$$::"[w l=8][line8]"[lr]::
62147::$$$message_0571_0022_0001$$$::A Sakura deve ter desistido, pois ao chegar no quarto de convidados, ela estĂĄ quieta.[lr]::
62148::$$$message_0571_0022_0002$$$::Ela abaixa a cabeĂ§a, mas segue minhas ordens.[lr]::
62149::$$$message_0571_0022_0003$$$::Apesar de seu rosto estar vermelho de febre, nĂŁo parece tĂŁo ruim.::
62150::$$$message_0571_0023_0000$$$::Saio do quarto dela.[lr]::
62151::$$$message_0571_0023_0001$$$::Vou mudar o menu de hoje.[lr]::
62152::$$$message_0571_0023_0002$$$::Tenho que correr e fazer um pouco de mingau de arroz para retribuir o favor.::
62153::$$$message_0571_0024_0000$$$::SĂŁo quase dez horas.[lr]::
62154::$$$message_0571_0024_0001$$$::Jantamos, e Ă© hora de patrulhar a regiĂŁo.::
62155::$$$message_0571_0025_0000$$$::"......"[lr]::
62156::$$$message_0571_0025_0001$$$::A Sakura estĂĄ dormindo no quarto de convidados.[lr]::
62157::$$$message_0571_0025_0002$$$::Jantei com a Saber.[lr]::
62158::$$$message_0571_0025_0003$$$::A Fuji-Nee nunca veio, entĂŁo ela deve estar ocupada hoje.::
62159::$$$message_0571_0026_0000$$$::"Shirou. EstĂĄ quase na hora."[lr]::
62160::$$$message_0571_0026_0001$$$::"......"[lr]::
62161::$$$message_0571_0026_0002$$$::A Saber me incita.[lr]::
62162::$$$message_0571_0026_0003$$$::Hoje a noite[w l=4][line4][lr]¶} è